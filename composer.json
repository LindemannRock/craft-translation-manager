{
	"name": "lindemannrock/craft-translation-manager",
	"description": "Localize your Craft interface and Formie & Freeform forms across every language — from the Control Panel",
	"type": "craft-plugin",
	"version": "5.32.0",
	"keywords": [
		"craft",
		"cms",
		"craftcms",
		"craft-plugin",
		"translation",
		"formie",
		"freeform",
		"multilingual"
	],
	"license": "proprietary",
	"authors": [
		{
			"name": "Bilal Hary Lindemann",
			"email": "bh@lindemannrock.com",
			"homepage": "https://lindemannrock.com",
			"role": "Developer"
		}
	],
	"support": {
		"email": "support@lindemannrock.com",
		"issues": "https://github.com/LindemannRock/craft-translation-manager/issues",
		"source": "https://github.com/LindemannRock/craft-translation-manager",
		"docs": "https://github.com/LindemannRock/craft-translation-manager/blob/main/README.md",
		"rss": "https://github.com/LindemannRock/craft-translation-manager/commits/main.atom"
	},
	"require": {
		"php": "^8.2",
		"craftcms/cms": "^5.10",
		"lindemannrock/craft-logging-library": "^5.12.0",
		"lindemannrock/craft-plugin-base": "^5.28.1"
	},
	"require-dev": {
		"craftcms/ecs": "dev-main",
		"craftcms/phpstan": "dev-main",
		"phpunit/phpunit": "^11.0",
		"solspace/craft-freeform": "^5.0",
		"verbb/formie": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"lindemannrock\\translationmanager\\": "src/",
			"lindemannrock\\translationmanager\\tests\\": "tests/"
		}
	},
	"scripts": {
		"phpstan": "phpstan --ansi --memory-limit=1G",
		"check-cs": "ecs check --ansi",
		"fix-cs": "ecs check --fix --ansi",
		"test": "phpunit --colors=always",
		"ci": [
			"@phpstan",
			"@check-cs"
		],
		"ci:full": [
			"@ci",
			"@test"
		],
		"install-hooks": "git config core.hooksPath .githooks 2>/dev/null || true",
		"post-install-cmd": "@install-hooks",
		"post-update-cmd": "@install-hooks"
	},
	"config": {
		"allow-plugins": {
			"craftcms/plugin-installer": true,
			"yiisoft/yii2-composer": true,
			"php-http/discovery": true
		}
	},
	"extra": {
		"name": "Translation Manager",
		"handle": "translation-manager",
		"developer": "LindemannRock",
		"developerUrl": "https://lindemannrock.com",
		"documentationUrl": "https://github.com/LindemannRock/craft-translation-manager/blob/main/README.md",
		"changelogUrl": "https://github.com/LindemannRock/craft-translation-manager/blob/main/CHANGELOG.md",
		"class": "lindemannrock\\translationmanager\\TranslationManager"
	}
}
