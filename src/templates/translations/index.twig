{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# Permission booleans (canEdit, canApprove, canDelete, canExport, canGenerate*,
   hasAnyGeneratePermission) and `settings` arrive pre-computed from the
   controller. Filter values arrive pre-validated — no re-validation here. #}

{% set formProviders = craft.translationManager.getEnabledFormProviders() %}
{% set showTypeCol = formProviders|length and settings.enableSiteTranslations %}
{% set showCategoryCol = allCategories|length > 1 %}

{# Language switcher in crumbs #}
{% set activeLocaleMapping = settings.getActiveLocaleMapping() %}
{% set mappedSourceLocales = activeLocaleMapping|keys %}
{% if currentLanguage in mappedSourceLocales %}
    {% set currentLanguage = activeLocaleMapping[currentLanguage] %}
{% endif %}

{% set filteredLanguages = [] %}
{% for lang in uniqueLanguages %}
    {% if lang not in mappedSourceLocales %}
        {% set filteredLanguages = filteredLanguages|merge([lang]) %}
    {% endif %}
{% endfor %}

{% set crumbs = [] %}
{% if filteredLanguages|length > 1 %}
    {% set languageMenuItems = [] %}
    {% for lang in filteredLanguages %}
        {% set languageMenuItems = languageMenuItems|merge([{
            label: lang|upper,
            url: url('translation-manager/translations', {language: lang, status: status, type: type, origin: origin, category: category, search: search, sort: sort, dir: dir}),
            selected: lang == currentLanguage
        }]) %}
    {% endfor %}

    {% set crumbs = crumbs|merge([{
        id: 'language-crumb',
        icon: 'language',
        label: currentLanguage|upper,
        menu: {
            items: languageMenuItems,
            label: 'Select language'|t('translation-manager')
        }
    }]) %}
{% endif %}

{% set crumbs = crumbs|merge([
    {
        label: translationHelper.fullName|t('translation-manager'),
        url: url('translation-manager'),
    },
]) %}

{% set groupedFilter = {
    type: 'status',
    param: 'status',
    current: status,
    label: status == 'all' ? 'All'|t('translation-manager') : (status == 'draft' ? 'Draft'|t('translation-manager') : (status == 'unused' ? 'Unused'|t('translation-manager') : status|capitalize)),
    groups: [
        {
            param: 'status',
            current: status,
            colorSet: 'translationStatus',
            options: [
                { value: 'all', label: 'All'|t('translation-manager'), status: 'all' },
                { value: 'pending', label: 'Pending'|t('translation-manager'), colorKey: 'pending' },
                { value: 'draft', label: 'Draft'|t('translation-manager'), colorKey: 'draft' },
                { value: 'translated', label: 'Translated'|t('translation-manager'), colorKey: 'translated' },
                { value: 'unused', label: 'Unused'|t('translation-manager'), colorKey: 'unused' },
            ],
        }
    ],
} %}

{% if showTypeCol %}
    {% set groupedFilter = groupedFilter|merge({
        groups: groupedFilter.groups|merge([{
            header: 'Type'|t('translation-manager'),
            param: 'type',
            current: type,
            colorSet: 'translationTypes',
            options: [
                { value: 'all', label: 'All Types'|t('translation-manager'), status: 'all' },
                { value: 'forms', label: 'Forms'|t('translation-manager'), colorKey: 'forms' },
                { value: 'site', label: 'Site'|t('translation-manager'), colorKey: 'site' },
            ],
        }])
    }) %}
{% endif %}

{% set groupedFilter = groupedFilter|merge({
    groups: groupedFilter.groups|merge([{
        header: 'Origin'|t('translation-manager'),
        param: 'origin',
        current: origin,
        colorSet: 'translationOrigins',
        options: [
            { value: 'all', label: 'All Origins'|t('translation-manager'), status: 'all' },
            { value: 'ai', label: 'AI'|t('translation-manager'), colorKey: 'ai' },
            { value: 'manual', label: 'Manual'|t('translation-manager'), colorKey: 'manual' },
            { value: 'import', label: 'Import'|t('translation-manager'), colorKey: 'import' },
            { value: 'system', label: 'System'|t('translation-manager'), colorKey: 'system' },
        ],
    }])
}) %}

{% set filters = [groupedFilter] %}

{% if showCategoryCol %}
    {% set categoryOptions = [{ value: 'all', label: 'All Categories'|t('translation-manager') }] %}
    {% for cat in allCategories %}
        {% set categoryOptions = categoryOptions|merge([{ value: cat, label: cat|title }]) %}
    {% endfor %}

    {% set filters = filters|merge([{
        type: 'dropdown',
        param: 'category',
        current: category,
        label: category == 'all' ? 'All Categories'|t('translation-manager') : category|title,
        icon: 'tag',
        options: categoryOptions,
    }]) %}
{% endif %}

{% set columns = [] %}
{% if showTypeCol %}
    {% set columns = columns|merge([{key: 'type', label: 'Type'|t('translation-manager'), sortable: true, width: '90px', hideable: true}]) %}
{% endif %}
{% if showCategoryCol %}
    {% set columns = columns|merge([{key: 'category', label: 'Category'|t('translation-manager'), sortable: true, width: '120px', hideable: true}]) %}
{% endif %}
{% set columns = columns|merge([
    {key: 'translationKey', label: 'Translation Key'|t('translation-manager'), sortable: true, width: '260px', hideable: true},
    {key: 'translation', label: 'Translation ({language})'|t('translation-manager', {language: currentLanguage|upper}), sortable: true},
    {key: 'status', label: 'Status'|t('translation-manager'), sortable: true, width: '110px', hideable: true},
    {key: 'origin', label: 'Origin'|t('translation-manager'), width: '100px', hideable: true},
    {key: 'createdBy', label: 'Created By'|t('translation-manager'), width: '150px', hideable: true},
    {key: 'reviewedBy', label: 'Reviewed By'|t('translation-manager'), width: '150px', hideable: true},
    {key: 'reviewedAt', label: 'Reviewed At'|t('translation-manager'), width: '170px', hideable: true},
]) %}
{% set columns = columns|merge([{key: 'context', label: 'Context'|t('translation-manager'), width: '170px', hideable: true}]) %}

{% set tableConfig = {
    plugin: {
        handle: 'translation-manager',
        name: translationHelper.fullName,
    },
    page: {
        title: 'Translations'|t('translation-manager'),
        subnav: 'translations',
        crumbs: crumbs,
    },
    filters: filters,
    search: {
        placeholder: 'Search'|t('translation-manager'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: columns,
        items: translations,
        emptyMessage: 'No translations found.'|t('translation-manager'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {singular: 'entry'|t('translation-manager'), plural: 'entries'|t('translation-manager')},
    },
    checkboxes: canEdit or canDelete,
    rowActions: false,
} %}

{% block content %}
    <style>
        .translation-text {
            direction: {{ currentLanguage starts with 'ar' ? 'rtl' : 'ltr' }};
            font-family: system-ui, -apple-system, sans-serif;
            font-size: 1rem;
            line-height: 1.5;
            padding: 0.5rem;
            border: 1px solid #cdd8e4;
            border-radius: 0.25rem;
            width: 100%;
            min-height: 40px;
            resize: vertical;
            field-sizing: content;
            max-height: 300px;
            overflow-y: auto;
        }

        td[data-column='translationKey'] {
            white-space: pre-wrap;
            max-width: 260px;
        }

        td[data-column='translation'] {
            min-width: 360px;
        }

        td[data-column='type'],
        th[data-column='type'] {
            white-space: nowrap;
        }

        td[data-column='context'] {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        tr.tm-unsaved {
            background-color: #fff4e6;
            transition: background-color 0.2s ease;
        }
    </style>

    {{ parent() }}
{% endblock %}

{% block tableRow %}
    {% if showTypeCol %}
        <td data-column="type" class="lr-hideable-column">
            {% set providerLabel = craft.translationManager.getFormProviderLabelForContext(item.context) %}
            {% set typeKey = providerLabel ? 'forms' : 'site' %}
            {% if providerLabel %}
                {% set typeLabel = providerLabel %}
            {% else %}
                {% set typeLabel = 'Site'|t('translation-manager') %}
            {% endif %}

            {% include 'lindemannrock-base/_components/badge' with {
                label: typeLabel,
                value: typeKey,
                colorSet: 'translationTypes',
            } only %}
        </td>
    {% endif %}

    {% if showCategoryCol %}
        <td data-column="category" class="lr-hideable-column"><span class="light">{{ item.category }}</span></td>
    {% endif %}

    <td data-column="translationKey" class="lr-hideable-column">{{ item.translationKey|e }}</td>

    <td data-column="translation">
        <textarea class="translation-text" placeholder="{{ 'Enter translation for {language}...'|t('translation-manager', {language: currentLanguage|upper}) }}">{{ item.translation|e }}</textarea>
    </td>

    <td data-column="status" class="lr-hideable-column">
        {% set statusMap = {
            'unused': { label: 'Unused'|t('translation-manager'), value: 'unused' },
            'pending': { label: 'Pending'|t('translation-manager'), value: 'pending' },
            'draft': { label: 'Draft'|t('translation-manager'), value: 'draft' },
            'translated': { label: 'Translated'|t('translation-manager'), value: 'translated' },
        } %}
        {% set statusBadge = statusMap[item.status] ?? { label: item.status|title, value: 'unused' } %}
        {% if item.status == 'draft' and (item.translationOrigin ?? '') == 'ai' %}
            {% set statusBadge = statusBadge|merge({ label: 'AI Draft'|t('translation-manager') }) %}
        {% endif %}

        {% include 'lindemannrock-base/_components/badge' with {
            label: statusBadge.label,
            value: statusBadge.value,
            colorSet: 'translationStatus',
        } only %}
    </td>

    <td data-column="origin" class="lr-hideable-column">
        {% set originLabels = {
            'ai': 'AI'|t('translation-manager'),
            'manual': 'Manual'|t('translation-manager'),
            'import': 'Import'|t('translation-manager'),
            'system': 'System'|t('translation-manager'),
        } %}
        {% set originKey = item.translationOrigin ?? 'system' %}
        {% if originLabels[originKey] is not defined %}
            {% set originKey = 'system' %}
        {% endif %}

        {% include 'lindemannrock-base/_components/badge' with {
            label: originLabels[originKey],
            value: originKey,
            colorSet: 'translationOrigins',
        } only %}
    </td>

    <td data-column="createdBy" class="lr-hideable-column">
        <span class="light">{{ item.createdByEmail ?: '-' }}</span>
    </td>

    <td data-column="reviewedBy" class="lr-hideable-column">
        <span class="light">{{ item.reviewedByEmail ?: '-' }}</span>
    </td>

    <td data-column="reviewedAt" class="lr-hideable-column">
        <span class="light">{{ item.reviewedAtFormatted ?: '-' }}</span>
    </td>

    <td data-column="context" class="light lr-hideable-column" title="{{ item.context|e }}">{{ item.context|e }}</td>
{% endblock %}

{% block bulkActions %}
    {% if canEdit or canApprove %}
        {% include 'lindemannrock-base/_components/bulk-status-menu' with {
            label: 'Set status'|t('lindemannrock-base'),
            countId: 'tm-bulk-status-count',
            items: [
                canEdit ? {id: 'mark-draft-btn', label: 'Mark Draft'|t('translation-manager'), value: 'draft', colorSet: 'translationStatus'} : null,
                (canApprove or (canEdit and not settings.requireApproval)) ? {id: 'mark-translated-btn', label: 'Mark Translated'|t('translation-manager'), value: 'translated', colorSet: 'translationStatus'} : null,
            ]|filter(v => v is not null),
        } only %}
    {% endif %}

    {% if status == 'unused' and canDelete %}
        {% include 'lindemannrock-base/_components/bulk-actions-menu' with {
            label: 'Actions'|t('translation-manager'),
            countId: 'tm-bulk-actions-count',
            items: [
                {id: 'delete-selected-btn', label: 'Delete'|t('translation-manager'), class: 'error'},
            ],
        } only %}
    {% endif %}
{% endblock %}

{% block extraFooter %}
    {% if not settings.autoGenerate and hasAnyGeneratePermission %}
        <form>
            <button type="button" class="btn secondary menubtn" data-icon="settings" title="{{ 'action title: generate translation files'|t('translation-manager') }}" id="generate-menu-btn"></button>
            <div class="menu" data-align="right">
                <ul>
                    {% if canGenerateAll %}
                        <li><a href="#" id="generate-all-btn">{{ 'Generate All Files'|t('translation-manager') }}</a></li>
                    {% endif %}
                    {% for provider in formProviders %}
                        {% if provider.available and provider.canGenerate %}
                            <li><a href="#" class="generate-provider-btn" data-provider="{{ provider.name }}">{{ 'Generate {name} Files Only'|t('translation-manager', {name: provider.label}) }}</a></li>
                        {% endif %}
                    {% endfor %}
                    {% if settings.enableSiteTranslations and canGenerateSite %}
                        <li><a href="#" id="generate-site-btn">{{ 'Generate {name} Files Only'|t('translation-manager', {name: settings.translationCategory|title}) }}</a></li>
                    {% endif %}
                </ul>
            </div>
        </form>
    {% endif %}

    {% if canExport %}
        {% include 'lindemannrock-base/_components/export-menu' with {
            action: 'translation-manager/export',
            permission: 'translationManager:exportTranslations',
            pluginHandle: 'translation-manager',
            selectionAware: true,
            idsParam: 'ids',
            extraParams: {
                language: currentLanguage,
                type: type,
                status: status,
                origin: origin,
                search: search,
                category: category,
            },
        } only %}
    {% endif %}

    {% if canEdit %}
        <button type="button" class="btn submit" id="save-all-btn" tabindex="0">
            <div class="gap-xs inline-flex"><div class="label">{{ 'Save All Changes'|t('translation-manager') }}</div></div>
            <div class="spinner spinner-absolute"></div>
        </button>
    {% endif %}
{% endblock %}

{% block scripts %}
    <script>
        // Pre-translated strings — keep |t() in Twig (translatable) and emit
        // as JSON-encoded JS literals via |json_encode|raw.
        const T = {
            markDraft: {{ 'Mark Draft'|t('translation-manager')|json_encode|raw }},
            markTranslated: {{ 'Mark Translated'|t('translation-manager')|json_encode|raw }},
            updateStatusFailed: {{ 'Failed to update status'|t('translation-manager')|json_encode|raw }},
            markDraftFailed: {{ 'Failed to mark as draft'|t('translation-manager')|json_encode|raw }},
            markTranslatedFailed: {{ 'Failed to mark as translated'|t('translation-manager')|json_encode|raw }},
            updatedTemplate: {{ 'Updated {count} translation(s) to {status}.'|t('translation-manager')|json_encode|raw }},
            translatedLabel: {{ 'status label: translated'|t('translation-manager')|json_encode|raw }},
            draftLabel: {{ 'status label: draft'|t('translation-manager')|json_encode|raw }},
            deleteConfirmSingular: {{ 'Are you sure you want to delete {count} translation?'|t('translation-manager')|json_encode|raw }},
            deleteConfirmPlural: {{ 'Are you sure you want to delete {count} translations?'|t('translation-manager')|json_encode|raw }},
            deletedTemplate: {{ 'Deleted {count} translation(s).'|t('translation-manager')|json_encode|raw }},
            deleteFailed: {{ 'Failed to delete translations'|t('translation-manager')|json_encode|raw }},
            saveFailed: {{ 'Failed to save'|t('translation-manager')|json_encode|raw }},
            saveTranslationFailed: {{ 'Failed to save translation'|t('translation-manager')|json_encode|raw }},
            noChanges: {{ 'No changes to save'|t('translation-manager')|json_encode|raw }},
            savingTemplate: {{ 'Saving {count} translation(s)...'|t('translation-manager')|json_encode|raw }},
            successTemplate: {{ 'Successfully saved {count} translation(s).'|t('translation-manager')|json_encode|raw }},
            partialSuccessTemplate: {{ 'Saved {saved} translation(s), {failed} failed.'|t('translation-manager')|json_encode|raw }},
            unsavedConfirm: {{ 'You have unsaved translations. Are you sure you want to leave?'|t('translation-manager')|json_encode|raw }},
            generateSuccess: {{ 'Translation files generated successfully.'|t('translation-manager')|json_encode|raw }},
            generateFailed: {{ 'Failed to generate translation files.'|t('translation-manager')|json_encode|raw }},
        };

        function getSelectedIds() {
            if (window.lrTableSelection && typeof window.lrTableSelection.getSelectedIds === 'function') {
                return window.lrTableSelection.getSelectedIds();
            }
            return [];
        }

        function bulkSetStatus(targetStatus, errorFallback) {
            const ids = getSelectedIds();
            if (!ids.length) return;

            Craft.sendActionRequest('POST', 'translation-manager/translations/set-status', {
                data: { ids: ids, status: targetStatus },
            }).then(function(response) {
                if (response.data.success) {
                    if (!response.data.updated) {
                        Craft.cp.displayError(T.noChanges);
                        return;
                    }

                    const label = targetStatus === 'translated' ? T.translatedLabel : T.draftLabel;
                    Craft.cp.displayNotice(
                        T.updatedTemplate.replace('{count}', response.data.updated).replace('{status}', label)
                    );
                    setTimeout(function() { window.location.reload(); }, 600);
                } else {
                    Craft.cp.displayError(response.data.error || errorFallback);
                }
            }).catch(function() {
                Craft.cp.displayError(errorFallback);
            });
        }

        {% if canEdit %}
        document.getElementById('mark-draft-btn')?.addEventListener('click', function() {
            bulkSetStatus('draft', T.markDraftFailed);
        });
        {% endif %}

        {% if canApprove or (canEdit and not settings.requireApproval) %}
        document.getElementById('mark-translated-btn')?.addEventListener('click', function() {
            bulkSetStatus('translated', T.markTranslatedFailed);
        });
        {% endif %}

        {% if status == 'unused' and canDelete %}
        document.getElementById('delete-selected-btn')?.addEventListener('click', function(e) {
            e.preventDefault();
            const ids = getSelectedIds();
            if (!ids.length) return;

            const confirmTemplate = ids.length === 1 ? T.deleteConfirmSingular : T.deleteConfirmPlural;
            if (!confirm(confirmTemplate.replace('{count}', ids.length))) return;

            Craft.sendActionRequest('POST', 'translation-manager/translations/delete', {
                data: { ids: ids },
            }).then(function(response) {
                if (response.data.success) {
                    Craft.cp.displayNotice(T.deletedTemplate.replace('{count}', response.data.deleted));
                    setTimeout(function() { window.location.reload(); }, 800);
                } else {
                    Craft.cp.displayError(response.data.error || T.deleteFailed);
                }
            }).catch(function() {
                Craft.cp.displayError(T.deleteFailed);
            });
        });
        {% endif %}

        class TranslationTracker {
            constructor() {
                this.unsavedChanges = new Map();
                this.originalValues = new Map();
                this.savingInProgress = new Set();
            }

            init() {
                document.querySelectorAll('.translation-text').forEach(textarea => {
                    const id = textarea.closest('tr').dataset.id;
                    this.originalValues.set(id, textarea.value.trim());
                });
            }

            markChanged(id, value) {
                const original = this.originalValues.get(id) || '';
                if (value.trim() !== original) {
                    this.unsavedChanges.set(id, value);
                } else {
                    this.unsavedChanges.delete(id);
                }
                this.updateUI(id);
            }

            markSaved(id, value) {
                this.unsavedChanges.delete(id);
                this.originalValues.set(id, value.trim());
                this.updateUI(id);
            }

            updateUI(id) {
                const row = document.querySelector(`tr[data-id="${id}"]`);
                if (!row) {
                    return;
                }
                row.classList.toggle('tm-unsaved', this.unsavedChanges.has(id));
            }

            hasUnsavedChanges() {
                return this.unsavedChanges.size > 0;
            }

            getUnsavedChanges() {
                return Array.from(this.unsavedChanges.entries()).map(([id, translationText]) => ({
                    id,
                    translation: translationText
                }));
            }
        }

        const tracker = new TranslationTracker();
        tracker.init();

        const statusLabels = {
            translated: {{ 'Translated'|t('translation-manager')|json_encode|raw }},
            draft: {{ 'Draft'|t('translation-manager')|json_encode|raw }},
            pending: {{ 'Pending'|t('translation-manager')|json_encode|raw }},
            unused: {{ 'Unused'|t('translation-manager')|json_encode|raw }},
        };

        function updateStatusDisplay(row, status) {
            const statusCell = row.querySelector('td[data-column="status"]');
            if (!statusCell) {
                return;
            }

            const colorMap = { translated: 'teal', draft: 'blue', pending: 'orange', unused: 'gray' };
            const color = colorMap[status];
            const label = statusLabels[status];
            let statusHtml = '';
            if (color && label) {
                statusHtml = `<span class="status-label ${color}"><span class="status ${color}"></span><span class="status-label-text">${label}</span></span>`;
            }

            if (statusHtml) {
                statusCell.innerHTML = statusHtml;
            }
        }

        async function saveTranslation(id, translationText) {
            if (tracker.savingInProgress.has(id)) {
                return false;
            }

            tracker.savingInProgress.add(id);
            const row = document.querySelector(`tr[data-id="${id}"]`);
            const textarea = row?.querySelector('.translation-text');
            if (!row || !textarea) {
                tracker.savingInProgress.delete(id);
                return false;
            }

            textarea.style.opacity = '0.6';

            try {
                const response = await Craft.sendActionRequest('POST', 'translation-manager/translations/save', {
                    data: { id: id, translation: translationText },
                });

                const data = response.data;
                if (!data.success) {
                    throw new Error(data.error || T.saveFailed);
                }

                tracker.markSaved(id, translationText);
                if (data.status) {
                    updateStatusDisplay(row, data.status);
                }

                row.style.backgroundColor = '#d4edda';
                setTimeout(() => {
                    row.style.backgroundColor = '';
                }, 700);
                return true;
            } catch (error) {
                console.error('Save error:', error);
                row.style.backgroundColor = '#fee';
                setTimeout(() => {
                    row.style.backgroundColor = '';
                }, 1600);
                Craft.cp.displayError(T.saveTranslationFailed);
                return false;
            } finally {
                tracker.savingInProgress.delete(id);
                textarea.style.opacity = '';
            }
        }

        document.querySelectorAll('.translation-text').forEach(textarea => {
            const row = textarea.closest('tr');
            const id = row.dataset.id;

            textarea.addEventListener('input', function() {
                tracker.markChanged(id, this.value);
            });

            textarea.addEventListener('blur', function() {
                if (tracker.unsavedChanges.has(id) && {{ settings.autoSaveEnabled|json_encode|raw }}) {
                    setTimeout(() => saveTranslation(id, this.value), 250);
                }
            });

            textarea.addEventListener('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                    e.preventDefault();
                    if (tracker.unsavedChanges.has(id)) {
                        saveTranslation(id, this.value);
                    }
                }
            });
        });

        {% if canEdit %}
        document.getElementById('save-all-btn')?.addEventListener('click', async function() {
            const unsavedChanges = tracker.getUnsavedChanges();
            if (unsavedChanges.length === 0) {
                Craft.cp.displayNotice(T.noChanges);
                return;
            }

            const btn = this;
            btn.disabled = true;
            btn.classList.add('loading');

            Craft.cp.displayNotice(T.savingTemplate.replace('{count}', unsavedChanges.length));

            let saved = 0;
            let failed = 0;
            const batchSize = 20;

            for (let i = 0; i < unsavedChanges.length; i += batchSize) {
                const batch = unsavedChanges.slice(i, i + batchSize);
                const promises = batch.map(({ id, translation }) =>
                    saveTranslation(id, translation).then(success => {
                        if (success) {
                            saved++;
                        } else {
                            failed++;
                        }
                        return success;
                    })
                );
                await Promise.all(promises);
            }

            if (failed === 0) {
                Craft.cp.displayNotice(T.successTemplate.replace('{count}', saved));
            } else {
                Craft.cp.displayError(T.partialSuccessTemplate.replace('{saved}', saved).replace('{failed}', failed));
            }

            btn.disabled = false;
            btn.classList.remove('loading');
        });
        {% endif %}

        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                document.getElementById('save-all-btn')?.click();
            }
        });

        window.addEventListener('beforeunload', function(e) {
            if (tracker.hasUnsavedChanges()) {
                e.preventDefault();
                e.returnValue = T.unsavedConfirm;
                return e.returnValue;
            }
        });

        {% if not settings.autoGenerate and hasAnyGeneratePermission %}
        function generateTranslationFiles(type) {
            let endpoint = '';
            let data = {};
            if (type === 'all') {
                endpoint = 'translation-manager/generate/files';
            } else if (type.startsWith('provider:')) {
                endpoint = 'translation-manager/generate/provider-files';
                data.provider = type.substring(9);
            } else if (type === 'site') {
                endpoint = 'translation-manager/generate/site-files';
            }

            Craft.sendActionRequest('POST', endpoint, {data}).then(function(response) {
                const data = response.data;
                if (data.success) {
                    Craft.cp.displayNotice(data.message || T.generateSuccess);
                } else {
                    Craft.cp.displayError(data.error || T.generateFailed);
                }
            }).catch(function() {
                Craft.cp.displayError(T.generateFailed);
            });
        }

        document.getElementById('generate-all-btn')?.addEventListener('click', function(e) {
            e.preventDefault();
            generateTranslationFiles('all');
        });

        document.querySelectorAll('.generate-provider-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                generateTranslationFiles('provider:' + this.dataset.provider);
            });
        });

        document.getElementById('generate-site-btn')?.addEventListener('click', function(e) {
            e.preventDefault();
            generateTranslationFiles('site');
        });
        {% endif %}
    </script>
{% endblock %}
