{% extends 'lindemannrock-base/_layouts/cp-table' %}

{% set plugin = craft.app.plugins.getPlugin('translation-manager') %}
{% set settings = plugin.settings %}

{% set canEditTranslations = currentUser.can('translationManager:editTranslations') %}
{% set canApproveTranslations = currentUser.can('translationManager:approveTranslations') %}
{% set canDeleteTranslations = currentUser.can('translationManager:deleteTranslations') %}
{% set canExportTranslations = currentUser.can('translationManager:exportTranslations') %}

{% set showTypeCol = settings.enableFormieIntegration and settings.enableSiteTranslations %}
{% set showCategoryCol = allCategories|length > 1 %}

{# Language switcher in crumbs #}
{% set activeLocaleMapping = settings.getActiveLocaleMapping() %}
{% set mappedSourceLocales = activeLocaleMapping|keys %}
{% if currentLanguage in mappedSourceLocales %}
    {% set currentLanguage = activeLocaleMapping[currentLanguage] %}
{% endif %}

{% set filteredLanguages = [] %}
{% for lang in uniqueLanguages %}
    {% if lang not in mappedSourceLocales %}
        {% set filteredLanguages = filteredLanguages|merge([lang]) %}
    {% endif %}
{% endfor %}

{% set crumbs = [] %}
{% if filteredLanguages|length > 1 %}
    {% set languageMenuItems = [] %}
    {% for lang in filteredLanguages %}
        {% set languageMenuItems = languageMenuItems|merge([{
            label: lang|upper,
            url: url('translation-manager/translations', {language: lang, status: status, type: type, origin: origin, category: category, search: search, sort: sort, dir: dir}),
            selected: lang == currentLanguage
        }]) %}
    {% endfor %}

    {% set crumbs = crumbs|merge([{
        id: 'language-crumb',
        icon: 'language',
        label: currentLanguage|upper,
        menu: {
            items: languageMenuItems,
            label: 'Select language'|t('translation-manager')
        }
    }]) %}
{% endif %}

{% set crumbs = crumbs|merge([
    {
        label: translationHelper.fullName|t('translation-manager'),
        url: url('translation-manager'),
    },
]) %}

{% set groupedFilter = {
    type: 'status',
    param: 'status',
    current: status,
    label: status == 'all' ? 'All'|t('translation-manager') : (status == 'draft' ? 'Draft'|t('translation-manager') : (status == 'unused' ? 'Unused'|t('translation-manager') : status|capitalize)),
    groups: [
        {
            param: 'status',
            current: status,
            options: [
                { value: 'all', label: 'All'|t('translation-manager'), status: 'all' },
                { value: 'pending', label: 'Pending'|t('translation-manager'), statusColor: '#f59e0b' },
                { value: 'draft', label: 'Draft'|t('translation-manager'), statusColor: '#3b82f6' },
                { value: 'translated', label: 'Translated'|t('translation-manager'), statusColor: '#14b8a6' },
                { value: 'unused', label: 'Unused'|t('translation-manager'), statusColor: '#64748b' },
            ],
        }
    ],
} %}

{% if showTypeCol %}
    {% set groupedFilter = groupedFilter|merge({
        groups: groupedFilter.groups|merge([{
            header: 'Type'|t('translation-manager'),
            param: 'type',
            current: type,
            options: [
                { value: 'all', label: 'All Types'|t('translation-manager'), status: 'all' },
                { value: 'forms', label: craft.translationManager.getFormiePluginName(), statusColor: '#3b82f6' },
                { value: 'site', label: 'Site'|t('translation-manager'), statusColor: '#14b8a6' },
            ],
        }])
    }) %}
{% endif %}

{% set groupedFilter = groupedFilter|merge({
    groups: groupedFilter.groups|merge([{
        header: 'Origin'|t('translation-manager'),
        param: 'origin',
        current: origin,
        options: [
            { value: 'all', label: 'All Origins'|t('translation-manager'), status: 'all' },
            { value: 'ai', label: 'AI'|t('translation-manager'), statusColor: '#7c3aed' },
            { value: 'manual', label: 'Manual'|t('translation-manager'), statusColor: '#16a34a' },
            { value: 'import', label: 'Import'|t('translation-manager'), statusColor: '#dc2626' },
            { value: 'system', label: 'System'|t('translation-manager'), statusColor: '#475569' },
        ],
    }])
}) %}

{% set filters = [groupedFilter] %}

{% if showCategoryCol %}
    {% set categoryOptions = [{ value: 'all', label: 'All Categories'|t('translation-manager') }] %}
    {% for cat in allCategories %}
        {% set categoryOptions = categoryOptions|merge([{ value: cat, label: cat|title }]) %}
    {% endfor %}

    {% set filters = filters|merge([{
        type: 'dropdown',
        param: 'category',
        current: category,
        label: category == 'all' ? 'All Categories'|t('translation-manager') : category|title,
        icon: 'tag',
        options: categoryOptions,
    }]) %}
{% endif %}

{% set columns = [] %}
{% if showTypeCol %}
    {% set columns = columns|merge([{key: 'type', label: 'Type'|t('translation-manager'), sortable: true, width: '90px', hideable: true}]) %}
{% endif %}
{% if showCategoryCol %}
    {% set columns = columns|merge([{key: 'category', label: 'Category'|t('translation-manager'), sortable: true, width: '120px', hideable: true}]) %}
{% endif %}
{% set columns = columns|merge([
    {key: 'translationKey', label: 'Translation Key'|t('translation-manager'), sortable: true, width: '260px', hideable: true},
    {key: 'translation', label: 'Translation ({language})'|t('translation-manager', {language: currentLanguage|upper}), sortable: true},
    {key: 'status', label: 'Status'|t('translation-manager'), sortable: true, width: '110px', hideable: true},
    {key: 'origin', label: 'Origin'|t('translation-manager'), width: '100px', hideable: true},
    {key: 'createdBy', label: 'Created By'|t('translation-manager'), width: '150px', hideable: true},
    {key: 'reviewedBy', label: 'Reviewed By'|t('translation-manager'), width: '150px', hideable: true},
    {key: 'reviewedAt', label: 'Reviewed At'|t('translation-manager'), width: '170px', hideable: true},
]) %}
{% set columns = columns|merge([{key: 'context', label: 'Context'|t('translation-manager'), width: '170px', hideable: true}]) %}

{% set hasAnyGeneratePermission =
    currentUser.can('translationManager:generateTranslations') or
    currentUser.can('translationManager:generateAllTranslations') or
    currentUser.can('translationManager:generateFormieTranslations') or
    currentUser.can('translationManager:generateSiteTranslations')
%}

{% set tableConfig = {
    plugin: {
        handle: 'translation-manager',
        name: translationHelper.fullName,
    },
    page: {
        title: 'Translations'|t('translation-manager'),
        subnav: 'translations',
        crumbs: crumbs,
    },
    filters: filters,
    search: {
        placeholder: 'Search'|t('translation-manager'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: columns,
        items: translations,
        emptyMessage: 'No translations found.'|t('translation-manager'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {singular: 'entry'|t('translation-manager'), plural: 'entries'|t('translation-manager')},
    },
    checkboxes: canEditTranslations or canDeleteTranslations,
    rowActions: false,
} %}

{% block content %}
    <style>
        .translation-text {
            direction: {{ currentLanguage starts with 'ar' ? 'rtl' : 'ltr' }};
            font-family: system-ui, -apple-system, sans-serif;
            font-size: 1rem;
            line-height: 1.5;
            padding: 0.5rem;
            border: 1px solid #cdd8e4;
            border-radius: 0.25rem;
            width: 100%;
            min-height: 40px;
            resize: vertical;
            field-sizing: content;
            max-height: 300px;
            overflow-y: auto;
        }

        td[data-column='translationKey'] {
            white-space: pre-wrap;
            max-width: 260px;
        }

        td[data-column='translation'] {
            min-width: 360px;
        }

        td[data-column='type'],
        th[data-column='type'] {
            white-space: nowrap;
        }

        td[data-column='context'] {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        tr.tm-unsaved {
            background-color: #fff4e6;
            transition: background-color 0.2s ease;
        }
    </style>

    {{ parent() }}
{% endblock %}

{% block tableRow %}
    {% if showTypeCol %}
        <td data-column="type" class="lr-hideable-column">
            {% if item.context starts with 'formie.' %}
                <span class="light">{{ craft.translationManager.getFormiePluginName() }}</span>
            {% else %}
                <span class="light">{{ 'Site'|t('translation-manager') }}</span>
            {% endif %}
        </td>
    {% endif %}

    {% if showCategoryCol %}
        <td data-column="category" class="lr-hideable-column"><span class="light">{{ item.category }}</span></td>
    {% endif %}

    <td data-column="translationKey" class="lr-hideable-column">{{ item.translationKey|e }}</td>

    <td data-column="translation">
        <textarea class="translation-text" placeholder="{{ 'Enter translation for {language}…'|t('translation-manager', {language: currentLanguage|upper}) }}">{{ item.translation|e }}</textarea>
    </td>

    <td data-column="status" class="lr-hideable-column">
        {% set statusMap = {
            'unused': { label: 'Unused'|t('translation-manager'), color: 'gray' },
            'pending': { label: 'Pending'|t('translation-manager'), color: 'orange' },
            'draft': { label: 'Draft'|t('translation-manager'), color: 'blue' },
            'translated': { label: 'Translated'|t('translation-manager'), color: 'teal' },
        } %}
        {% set statusBadge = statusMap[item.status] ?? { label: item.status|title, color: 'gray' } %}
        {% if item.status == 'draft' and (item.translationOrigin ?? '') == 'ai' %}
            {% set statusBadge = statusBadge|merge({ label: 'AI Draft'|t('translation-manager') }) %}
        {% endif %}

        {% include 'lindemannrock-base/_components/status-badge' with {
            label: statusBadge.label,
            status: statusBadge.color,
        } only %}
    </td>

    <td data-column="origin" class="lr-hideable-column">
        {% set originMap = {
            'ai': { label: 'AI'|t('translation-manager'), color: '#7c3aed', rgb: '124, 58, 237', text: '#4c1d95' },
            'manual': { label: 'Manual'|t('translation-manager'), color: '#16a34a', rgb: '22, 163, 74', text: '#14532d' },
            'import': { label: 'Import'|t('translation-manager'), color: '#dc2626', rgb: '220, 38, 38', text: '#7f1d1d' },
            'system': { label: 'System'|t('translation-manager'), color: '#475569', rgb: '71, 85, 105', text: '#1e293b' },
        } %}
        {% set originKey = item.translationOrigin ?? 'system' %}
        {% set originBadge = originMap[originKey] ?? originMap['system'] %}

        {% include 'lindemannrock-base/_components/status-badge' with {
            label: originBadge.label,
            color: originBadge.color,
            rgb: originBadge.rgb,
            textColor: originBadge.text,
        } only %}
    </td>

    <td data-column="createdBy" class="lr-hideable-column">
        <span class="light">{{ item.createdByEmail ?: '-' }}</span>
    </td>

    <td data-column="reviewedBy" class="lr-hideable-column">
        <span class="light">{{ item.reviewedByEmail ?: '-' }}</span>
    </td>

    <td data-column="reviewedAt" class="lr-hideable-column">
        <span class="light">{{ item.reviewedAtFormatted ?: '-' }}</span>
    </td>

    <td data-column="context" class="light lr-hideable-column" title="{{ item.context|e }}">{{ item.context|e }}</td>
{% endblock %}

{% block bulkActions %}
    {% if canEditTranslations %}
        <button type="button" class="btn secondary" id="mark-draft-btn">
            <span id="mark-draft-label">{{ 'Mark Draft'|t('translation-manager') }}</span>
        </button>
    {% endif %}

    {% if canApproveTranslations or (canEditTranslations and not settings.requireApproval) %}
        <button type="button" class="btn secondary" id="mark-translated-btn">
            <span id="mark-translated-label">{{ 'Mark Translated'|t('translation-manager') }}</span>
        </button>
    {% endif %}

    {% if status == 'unused' and canDeleteTranslations %}
        <button type="button" class="btn secondary" id="delete-selected-btn">
            <span id="delete-label">{{ 'Delete'|t('translation-manager') }}</span>
        </button>
    {% endif %}
{% endblock %}

{% block extraFooter %}
    {% if not settings.autoExport and hasAnyGeneratePermission %}
        <form>
            <button type="button" class="btn secondary menubtn" data-icon="settings" title="{{ 'Generate translation files'|t('translation-manager') }}" id="generate-menu-btn"></button>
            <div class="menu" data-align="right">
                <ul>
                    {% if currentUser.can('translationManager:generateAllTranslations') %}
                        <li><a href="#" id="generate-all-btn">{{ 'Generate All Files'|t('translation-manager') }}</a></li>
                    {% endif %}
                    {% if settings.enableFormieIntegration and currentUser.can('translationManager:generateFormieTranslations') %}
                        <li><a href="#" id="generate-formie-btn">{{ 'Generate {name} Files Only'|t('translation-manager', {name: craft.translationManager.getFormiePluginName()}) }}</a></li>
                    {% endif %}
                    {% if settings.enableSiteTranslations and currentUser.can('translationManager:generateSiteTranslations') %}
                        <li><a href="#" id="generate-site-btn">{{ 'Generate {name} Files Only'|t('translation-manager', {name: settings.translationCategory|title}) }}</a></li>
                    {% endif %}
                </ul>
            </div>
        </form>
    {% endif %}

    {% if canExportTranslations %}
        <button type="button" class="btn" id="export-btn" tabindex="0" aria-expanded="false" title="{{ 'Export translations as CSV file'|t('translation-manager') }}">{{ 'Export…'|t('translation-manager') }}</button>
    {% endif %}

    {% if canEditTranslations %}
        <button type="button" class="btn submit" id="save-all-btn" tabindex="0">
            <div class="gap-xs inline-flex"><div class="label">{{ 'Save All Changes'|t('translation-manager') }}</div></div>
            <div class="spinner spinner-absolute"></div>
        </button>
    {% endif %}
{% endblock %}

{% block scripts %}
    <script>
        function getSelectedIds() {
            if (window.lrTableSelection && typeof window.lrTableSelection.getSelectedIds === 'function') {
                return window.lrTableSelection.getSelectedIds();
            }
            return [];
        }

        function updateActionButtons(count) {
            {% if canEditTranslations %}
            const markDraftLabel = document.getElementById('mark-draft-label');
            if (markDraftLabel) {
                markDraftLabel.textContent = count > 0
                    ? `{{ 'Mark Draft'|t('translation-manager') }} (${count})`
                    : `{{ 'Mark Draft'|t('translation-manager') }}`;
            }
            {% endif %}

            {% if canApproveTranslations or (canEditTranslations and not settings.requireApproval) %}
            const markTranslatedLabel = document.getElementById('mark-translated-label');
            if (markTranslatedLabel) {
                markTranslatedLabel.textContent = count > 0
                    ? `{{ 'Mark Translated'|t('translation-manager') }} (${count})`
                    : `{{ 'Mark Translated'|t('translation-manager') }}`;
            }
            {% endif %}

            {% if status == 'unused' and canDeleteTranslations %}
            const deleteLabel = document.getElementById('delete-label');
            if (deleteLabel) {
                deleteLabel.textContent = count > 0
                    ? `{{ 'Delete'|t('translation-manager') }} (${count})`
                    : `{{ 'Delete'|t('translation-manager') }}`;
            }
            {% endif %}
        }

        document.addEventListener('lr:selectionChanged', function(e) {
            updateActionButtons(e.detail?.count || 0);
        });
        updateActionButtons(0);

        {% if canExportTranslations %}
        document.getElementById('export-btn')?.addEventListener('click', function(e) {
            e.preventDefault();

            const selectedIds = getSelectedIds();
            if (selectedIds.length > 0) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '{{ actionUrl('translation-manager/export/selected') }}';

                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = '{{ craft.app.config.general.csrfTokenName }}';
                csrfInput.value = '{{ craft.app.request.csrfToken }}';
                form.appendChild(csrfInput);

                const idsInput = document.createElement('input');
                idsInput.type = 'hidden';
                idsInput.name = 'ids';
                idsInput.value = JSON.stringify(selectedIds);
                form.appendChild(idsInput);

                document.body.appendChild(form);
                form.submit();
                document.body.removeChild(form);
            } else {
                const actionUrl = '{{ actionUrl('translation-manager/export') }}';
                const type = {{ type|json_encode|raw }};
                const status = {{ status|json_encode|raw }};
                const origin = {{ origin|json_encode|raw }};
                const search = {{ search|json_encode|raw }};
                const category = {{ category|json_encode|raw }};
                const language = {{ currentLanguage|json_encode|raw }};

                let url = actionUrl;
                url += (actionUrl.indexOf('?') === -1 ? '?' : '&') + 'language=' + encodeURIComponent(language);
                url += '&type=' + encodeURIComponent(type);
                url += '&status=' + encodeURIComponent(status);
                url += '&origin=' + encodeURIComponent(origin);
                url += '&search=' + encodeURIComponent(search);
                url += '&category=' + encodeURIComponent(category);

                window.location.href = url;
            }
        });
        {% endif %}

        async function bulkSetStatus(status) {
            const ids = getSelectedIds();
            if (ids.length === 0) {
                return;
            }

            const response = await fetch('{{ actionUrl('translation-manager/translations/set-status') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ ids, status })
            });

            const data = await response.json();
            if (!data.success) {
                throw new Error(data.error || {{ 'Failed to update status'|t('translation-manager')|json_encode|raw }});
            }

            const label = status === 'translated' ? {{ 'translated'|t('translation-manager')|json_encode|raw }} : {{ 'draft'|t('translation-manager')|json_encode|raw }};
            Craft.cp.displayNotice({{ 'Updated {count} translation(s) to {status}.'|t('translation-manager')|json_encode|raw }}.replace('{count}', data.updated).replace('{status}', label));
            setTimeout(() => window.location.reload(), 600);
        }

        {% if canEditTranslations %}
        document.getElementById('mark-draft-btn')?.addEventListener('click', async function() {
            try {
                await bulkSetStatus('draft');
            } catch (error) {
                console.error(error);
                Craft.cp.displayError(error.message || {{ 'Failed to mark as draft'|t('translation-manager')|json_encode|raw }});
            }
        });
        {% endif %}

        {% if canApproveTranslations or (canEditTranslations and not settings.requireApproval) %}
        document.getElementById('mark-translated-btn')?.addEventListener('click', async function() {
            try {
                await bulkSetStatus('translated');
            } catch (error) {
                console.error(error);
                Craft.cp.displayError(error.message || {{ 'Failed to mark as translated'|t('translation-manager')|json_encode|raw }});
            }
        });
        {% endif %}

        {% if status == 'unused' and canDeleteTranslations %}
        document.getElementById('delete-selected-btn')?.addEventListener('click', function(e) {
            e.preventDefault();
            const ids = getSelectedIds();
            if (ids.length === 0) {
                return;
            }

            if (!confirm({{ 'Are you sure you want to delete {count} translation(s)?'|t('translation-manager')|json_encode|raw }}.replace('{count}', ids.length))) {
                return;
            }

            fetch('{{ actionUrl('translation-manager/translations/delete') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ ids })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice({{ 'Deleted {count} translation(s).'|t('translation-manager')|json_encode|raw }}.replace('{count}', data.deleted));
                    setTimeout(() => window.location.reload(), 800);
                } else {
                    Craft.cp.displayError(data.error || {{ 'Failed to delete translations'|t('translation-manager')|json_encode|raw }});
                }
            })
            .catch(() => {
                Craft.cp.displayError({{ 'Failed to delete translations'|t('translation-manager')|json_encode|raw }});
            });
        });
        {% endif %}

        class TranslationTracker {
            constructor() {
                this.unsavedChanges = new Map();
                this.originalValues = new Map();
                this.savingInProgress = new Set();
            }

            init() {
                document.querySelectorAll('.translation-text').forEach(textarea => {
                    const id = textarea.closest('tr').dataset.id;
                    this.originalValues.set(id, textarea.value.trim());
                });
            }

            markChanged(id, value) {
                const original = this.originalValues.get(id) || '';
                if (value.trim() !== original) {
                    this.unsavedChanges.set(id, value);
                } else {
                    this.unsavedChanges.delete(id);
                }
                this.updateUI(id);
            }

            markSaved(id, value) {
                this.unsavedChanges.delete(id);
                this.originalValues.set(id, value.trim());
                this.updateUI(id);
            }

            updateUI(id) {
                const row = document.querySelector(`tr[data-id="${id}"]`);
                if (!row) {
                    return;
                }
                row.classList.toggle('tm-unsaved', this.unsavedChanges.has(id));
            }

            hasUnsavedChanges() {
                return this.unsavedChanges.size > 0;
            }

            getUnsavedChanges() {
                return Array.from(this.unsavedChanges.entries()).map(([id, translationText]) => ({
                    id,
                    translation: translationText
                }));
            }
        }

        const tracker = new TranslationTracker();
        tracker.init();

        const statusLabels = {
            translated: {{ 'Translated'|t('translation-manager')|json_encode|raw }},
            draft: {{ 'Draft'|t('translation-manager')|json_encode|raw }},
            pending: {{ 'Pending'|t('translation-manager')|json_encode|raw }},
            unused: {{ 'Unused'|t('translation-manager')|json_encode|raw }},
        };

        function updateStatusDisplay(row, status) {
            const statusCell = row.querySelector('td[data-column="status"]');
            if (!statusCell) {
                return;
            }

            const colorMap = { translated: 'teal', draft: 'blue', pending: 'orange', unused: 'gray' };
            const color = colorMap[status];
            const label = statusLabels[status];
            let statusHtml = '';
            if (color && label) {
                statusHtml = `<span class="status-label ${color}"><span class="status ${color}"></span><span class="status-label-text">${label}</span></span>`;
            }

            if (statusHtml) {
                statusCell.innerHTML = statusHtml;
            }
        }

        async function saveTranslation(id, translationText) {
            if (tracker.savingInProgress.has(id)) {
                return;
            }

            tracker.savingInProgress.add(id);
            const row = document.querySelector(`tr[data-id="${id}"]`);
            const textarea = row?.querySelector('.translation-text');
            if (!row || !textarea) {
                tracker.savingInProgress.delete(id);
                return;
            }

            textarea.style.opacity = '0.6';

            try {
                const response = await fetch('{{ actionUrl('translation-manager/translations/save') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ id, translation: translationText })
                });

                const data = await response.json();
                if (!data.success) {
                    throw new Error(data.error || {{ 'Failed to save'|t('translation-manager')|json_encode|raw }});
                }

                tracker.markSaved(id, translationText);
                if (data.status) {
                    updateStatusDisplay(row, data.status);
                }

                row.style.backgroundColor = '#d4edda';
                setTimeout(() => {
                    row.style.backgroundColor = '';
                }, 700);
            } catch (error) {
                console.error('Save error:', error);
                row.style.backgroundColor = '#fee';
                setTimeout(() => {
                    row.style.backgroundColor = '';
                }, 1600);
                Craft.cp.displayError({{ 'Failed to save translation'|t('translation-manager')|json_encode|raw }});
            } finally {
                tracker.savingInProgress.delete(id);
                textarea.style.opacity = '';
            }
        }

        document.querySelectorAll('.translation-text').forEach(textarea => {
            const row = textarea.closest('tr');
            const id = row.dataset.id;

            textarea.addEventListener('input', function() {
                tracker.markChanged(id, this.value);
            });

            textarea.addEventListener('blur', function() {
                if (tracker.unsavedChanges.has(id) && {{ settings.autoSaveEnabled|json_encode|raw }}) {
                    setTimeout(() => saveTranslation(id, this.value), 250);
                }
            });

            textarea.addEventListener('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                    e.preventDefault();
                    if (tracker.unsavedChanges.has(id)) {
                        saveTranslation(id, this.value);
                    }
                }
            });
        });

        {% if canEditTranslations %}
        document.getElementById('save-all-btn')?.addEventListener('click', async function() {
            const unsavedChanges = tracker.getUnsavedChanges();
            if (unsavedChanges.length === 0) {
                Craft.cp.displayNotice({{ 'No changes to save'|t('translation-manager')|json_encode|raw }});
                return;
            }

            const btn = this;
            btn.disabled = true;
            btn.classList.add('loading');

            Craft.cp.displayNotice({{ 'Saving {count} translation(s)…'|t('translation-manager')|json_encode|raw }}.replace('{count}', unsavedChanges.length));

            let saved = 0;
            let failed = 0;
            const batchSize = 20;

            for (let i = 0; i < unsavedChanges.length; i += batchSize) {
                const batch = unsavedChanges.slice(i, i + batchSize);
                const promises = batch.map(({ id, translation }) =>
                    saveTranslation(id, translation)
                        .then(() => {
                            saved++;
                            return true;
                        })
                        .catch(() => {
                            failed++;
                            return false;
                        })
                );
                await Promise.all(promises);
            }

            if (failed === 0) {
                Craft.cp.displayNotice({{ 'Successfully saved {count} translation(s).'|t('translation-manager')|json_encode|raw }}.replace('{count}', saved));
            } else {
                Craft.cp.displayError({{ 'Saved {saved} translation(s), {failed} failed.'|t('translation-manager')|json_encode|raw }}.replace('{saved}', saved).replace('{failed}', failed));
            }

            btn.disabled = false;
            btn.classList.remove('loading');
        });
        {% endif %}

        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                document.getElementById('save-all-btn')?.click();
            }
        });

        window.addEventListener('beforeunload', function(e) {
            if (tracker.hasUnsavedChanges()) {
                e.preventDefault();
                e.returnValue = {{ 'You have unsaved translations. Are you sure you want to leave?'|t('translation-manager')|json_encode|raw }};
                return e.returnValue;
            }
        });

        {% if not settings.autoExport and hasAnyGeneratePermission %}
        function generateTranslationFiles(type) {
            let url = '';
            if (type === 'all') {
                url = '{{ actionUrl('translation-manager/export/files') }}';
            } else if (type === 'formie') {
                url = '{{ actionUrl('translation-manager/export/formie-files') }}';
            } else if (type === 'site') {
                url = '{{ actionUrl('translation-manager/export/site-files') }}';
            }

            fetch(url, {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message || {{ 'Translation files generated successfully.'|t('translation-manager')|json_encode|raw }});
                } else {
                    Craft.cp.displayError(data.error || {{ 'Failed to generate translation files.'|t('translation-manager')|json_encode|raw }});
                }
            })
            .catch(() => {
                Craft.cp.displayError({{ 'Failed to generate translation files.'|t('translation-manager')|json_encode|raw }});
            });
        }

        document.getElementById('generate-all-btn')?.addEventListener('click', function(e) {
            e.preventDefault();
            generateTranslationFiles('all');
        });

        document.getElementById('generate-formie-btn')?.addEventListener('click', function(e) {
            e.preventDefault();
            generateTranslationFiles('formie');
        });

        document.getElementById('generate-site-btn')?.addEventListener('click', function(e) {
            e.preventDefault();
            generateTranslationFiles('site');
        });
        {% endif %}
    </script>
{% endblock %}
