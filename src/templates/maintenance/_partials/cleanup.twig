{% import "_includes/forms" as forms %}

{% set canUseMaintenanceCleanup = currentUser.can('translationManager:cleanMaintenanceArtifacts') %}
{% set orderedSources = deletableUnusedSources ?? craft.translationManager.getSources()|filter(source => source.canDeleteUnused) %}
{% set canDeleteUnusedTranslations = canDeleteAnyUnusedTranslations ?? (craft.translationManager.canDeleteAllUnusedTranslations() or orderedSources|length) %}

{% if canUseMaintenanceCleanup or canDeleteUnusedTranslations %}
{% if canDeleteUnusedTranslations %}
<div class="field">
    <div class="heading">
        <label>{{ "Delete Unused Translations"|t('translation-manager') }}</label>
        <div class="instructions">
            <p>{{ "Delete translations that are no longer used in templates or forms."|t('translation-manager') }}</p>
        </div>
    </div>
    <div class="input">
        {% set totalUnused = unusedCounts.total %}
        {% if totalUnused > 0 %}
            <div style="margin-bottom: 15px;">
                <p class="light">
                    {{ "You have {total} unused translation(s): {site} site translations and {forms} form translations"|t('translation-manager', {
                        total: totalUnused|number_format,
                        site: unusedCounts.site|number_format,
                        forms: unusedCounts.forms|number_format,
                    }) }}
                </p>
            </div>

            <div>
                {% set unusedOptions = [
                    {value: '', label: 'Select type'|t('translation-manager')},
                ] %}
                {% if craft.translationManager.canDeleteAllUnusedTranslations() %}
                    {% set unusedOptions = unusedOptions|merge([
                        {value: 'all', label: 'All Unused ({count})'|t('translation-manager', {count: totalUnused|number_format})}
                    ]) %}
                {% endif %}
                {% for source in orderedSources %}
                    {% set sourceValue = source.providerName ? 'provider:' ~ source.providerName : 'category:' ~ source.category %}
                    {% set count = source.providerName ? (unusedCounts.providers[source.providerName] ?? 0) : (unusedCounts[source.category] ?? 0) %}
                    {% set unusedOptions = unusedOptions|merge([{value: sourceValue, label: 'Unused ' ~ source.label ~ ' (' ~ (count|number_format) ~ ')'}]) %}
                {% endfor %}
                {{ forms.selectField({
                    label: "Unused Translations to Delete"|t('translation-manager'),
                    id: 'unusedType',
                    name: 'unusedType',
                    options: unusedOptions,
                    value: ''
                }) }}
                {% include 'lindemannrock-base/_components/info-box' with {
                    message: '',
                    type: settings.backupEnabled ? 'warning' : 'error',
                    variant: 'colored',
                    margin: 'both',
                    boxId: 'unusedDescription',
                    messageId: 'unusedDescriptionText',
                    hidden: true,
                    allowHtml: false,
                } %}
                {% include 'lindemannrock-base/_components/info-box' with {
                    message: "No unused translations found for the selected type."|t('translation-manager'),
                    type: 'info',
                    variant: 'subtle',
                    margin: 'both',
                    boxId: 'unusedNoItemsDescription',
                    hidden: true,
                    allowHtml: false,
                } %}
                <div style="margin-top: 8px;">
                    <button type="button" class="btn secondary" id="clean-unused-enhanced-btn" disabled>
                        {{ "Delete Unused Translations"|t('translation-manager') }}
                    </button>
                </div>
            </div>
        {% else %}
            <p class="light">{{ "No unused translations found. Run template scan below to identify unused translations."|t('translation-manager') }}</p>
        {% endif %}
    </div>
</div>

{% if canUseMaintenanceCleanup %}
<hr>
{% endif %}
{% endif %}

{% if canUseMaintenanceCleanup %}
<div class="field">
    <div class="heading">
        <label>{{ "Clean Removed Categories"|t('translation-manager') }}</label>
        <div class="instructions">
            <p>{{ "Remove translations for categories that still exist in the database but are no longer enabled (for example removed plugin categories)."|t('translation-manager') }}</p>
        </div>
    </div>
    <div class="input">
        {% if categoryCleanup.totalCandidates > 0 %}
            <div style="margin-bottom: 12px;">
                {% set candidateWord = categoryCleanup.totalCandidates == 1 ? "category"|t('translation-manager') : "categories"|t('translation-manager') %}
                {% set rowWord = categoryCleanup.totalRows == 1 ? "row"|t('translation-manager') : "rows"|t('translation-manager') %}
                <p class="light">{{ "Found {categories} removed {candidateWord} with {rows} total {rowWord}."|t('translation-manager', {categories: categoryCleanup.totalCandidates|number_format, rows: categoryCleanup.totalRows|number_format, candidateWord: candidateWord, rowWord: rowWord}) }}</p>
            </div>

            <div>
                {% set categoryCleanupOptions = [
                    {value: '', label: 'Select category'|t('translation-manager')}
                ] %}
                {% for row in categoryCleanup.removed %}
                    {% set categoryCleanupOptions = categoryCleanupOptions|merge([{
                        value: row.category,
                        label: row.category ~ ' (' ~ (row.count|number_format) ~ ' rows)'
                    }]) %}
                {% endfor %}
                {{ forms.selectField({
                    label: "Category to Clean Up"|t('translation-manager'),
                    id: 'cleanCategory',
                    name: 'cleanCategory',
                    options: categoryCleanupOptions,
                    value: ''
                }) }}
                {% include 'lindemannrock-base/_components/info-box' with {
                    message: '',
                    type: settings.backupEnabled ? 'warning' : 'error',
                    variant: 'colored',
                    margin: 'top',
                    boxId: 'categoryCleanupDescription',
                    messageId: 'categoryCleanupDescriptionText',
                    hidden: true,
                    allowHtml: false,
                } %}
                <div style="margin-top: 8px;">
                    <button type="button" class="btn secondary" id="clean-categories-btn" disabled>
                        {{ "Clean Category"|t('translation-manager') }}
                    </button>
                </div>
            </div>
        {% else %}
            <p class="light">{{ "No removed category rows found."|t('translation-manager') }}</p>
        {% endif %}
    </div>
</div>

<hr>

<div class="field">
    <div class="heading">
        <label>{{ "Clean Languages"|t('translation-manager') }}</label>
        <div class="instructions">
            <p>{{ "Optionally remove mapped-source and ghost language rows (for example old en-US or test languages like de)."|t('translation-manager') }}</p>
        </div>
    </div>
    <div class="input">
        {% if languageCleanup.totalCandidates > 0 %}
            <div style="margin-bottom: 12px;">
                {% set candidateWord = languageCleanup.totalCandidates == 1 ? "language"|t('translation-manager') : "languages"|t('translation-manager') %}
                {% set rowWord = languageCleanup.totalRows == 1 ? "row"|t('translation-manager') : "rows"|t('translation-manager') %}
                <p class="light">{{ "Found {langs} cleanup candidate {candidateWord} with {rows} total {rowWord}."|t('translation-manager', {langs: languageCleanup.totalCandidates|number_format, rows: languageCleanup.totalRows|number_format, candidateWord: candidateWord, rowWord: rowWord}) }}</p>
            </div>

            <div>
                {% set languageCleanupOptions = [
                    {value: '', label: 'Select language'|t('translation-manager')}
                ] %}
                {% for row in languageCleanup.mappedSource %}
                    {% set languageCleanupOptions = languageCleanupOptions|merge([{
                        value: row.language,
                        label: row.language ~ ' -> ' ~ row.mappedTo ~ ' (' ~ (row.count|number_format) ~ ' rows, mapped source)'
                    }]) %}
                {% endfor %}
                {% for row in languageCleanup.ghost %}
                    {% set languageCleanupOptions = languageCleanupOptions|merge([{
                        value: row.language,
                        label: row.language ~ ' (' ~ (row.count|number_format) ~ ' rows, ghost locale)'
                    }]) %}
                {% endfor %}
                {{ forms.selectField({
                    label: "Language to Clean Up"|t('translation-manager'),
                    id: 'cleanLanguage',
                    name: 'cleanLanguage',
                    options: languageCleanupOptions,
                    value: ''
                }) }}
                {% include 'lindemannrock-base/_components/info-box' with {
                    message: '',
                    type: settings.backupEnabled ? 'warning' : 'error',
                    variant: 'colored',
                    margin: 'both',
                    boxId: 'languageCleanupDescription',
                    messageId: 'languageCleanupDescriptionText',
                    hidden: true,
                    allowHtml: false,
                } %}
                <div style="margin-top: 8px;">
                    <button type="button" class="btn submit" id="migrate-clean-languages-btn" disabled style="display: none;">
                        {{ "Migrate & Delete"|t('translation-manager') }}
                    </button>
                    <button type="button" class="btn secondary" id="clean-languages-btn" disabled>
                        {{ "Delete Only"|t('translation-manager') }}
                    </button>
                </div>
            </div>
        {% else %}
            <p class="light">{{ "No mapped-source or ghost language rows found."|t('translation-manager') }}</p>
        {% endif %}
    </div>
</div>

<hr>

<div class="field">
    <div class="heading">
        <label>{{ "Clean Generated Files"|t('translation-manager') }}</label>
        <div class="instructions">
            <p>{{ "Optionally remove generated PHP files whose language folder or category is no longer a current generation target."|t('translation-manager') }}</p>
        </div>
    </div>
    <div class="input">
        {% if generatedFileCleanup.totalCandidates > 0 %}
            <div style="margin-bottom: 12px;">
                {% set fileWord = generatedFileCleanup.totalCandidates == 1 ? "file"|t('translation-manager') : "files"|t('translation-manager') %}
                <p class="light">{{ "Found {count} generated {fileWord} that can be reviewed for cleanup."|t('translation-manager', {count: generatedFileCleanup.totalCandidates|number_format, fileWord: fileWord}) }}</p>
            </div>

            <div>
                {% set generatedFileOptions = [
                    {value: '', label: 'Select generated file'|t('translation-manager')}
                ] %}
                {% for row in generatedFileCleanup.files %}
                    {% set reason = row.reason == 'language' ? 'language folder no longer generated'|t('translation-manager') : (row.reason == 'category' ? 'category no longer generated'|t('translation-manager') : 'language folder and category no longer generated'|t('translation-manager')) %}
                    {% set generatedFileOptions = generatedFileOptions|merge([{
                        value: row.path,
                        label: row.path ~ ' (' ~ reason ~ ')'
                    }]) %}
                {% endfor %}
                {{ forms.selectField({
                    label: "Generated File to Clean Up"|t('translation-manager'),
                    id: 'cleanGeneratedFile',
                    name: 'cleanGeneratedFile',
                    options: generatedFileOptions,
                    value: ''
                }) }}
                {% include 'lindemannrock-base/_components/info-box' with {
                    message: '',
                    type: 'warning',
                    variant: 'colored',
                    margin: 'both',
                    boxId: 'generatedFileCleanupDescription',
                    messageId: 'generatedFileCleanupDescriptionText',
                    hidden: true,
                    allowHtml: false,
                } %}
                <div style="margin-top: 8px;">
                    <button type="button" class="btn secondary" id="clean-generated-file-btn" disabled>
                        {{ "Delete Generated File"|t('translation-manager') }}
                    </button>
                </div>
            </div>
        {% else %}
            <p class="light">{{ "No orphaned generated PHP files found."|t('translation-manager') }}</p>
        {% endif %}
    </div>
</div>
{% endif %}
{% endif %}
