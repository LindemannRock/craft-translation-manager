{% import "_includes/forms" as forms %}

{% set orderedSources = craft.translationManager.getSources() %}
{% if craft.translationManager.canDeleteAllSources() or orderedSources|filter(source => source.canDelete)|length %}
<h2 class="error">{{ "Delete Translations"|t('translation-manager') }}</h2>

{% set translationCounts = craft.translationManager.getTranslationCounts() %}
{% set deleteOptions = [{ value: '', label: 'Select a source'|t('translation-manager') }] %}
{% if (enabledFormProviders|length or settings.enableSiteTranslations) and craft.translationManager.canDeleteAllSources() %}
    {% set deleteOptions = deleteOptions|merge([{ value: 'all', label: 'All (' ~ (translationCounts.total|number_format) ~ ')' }]) %}
{% endif %}
{% for source in orderedSources %}
    {% if source.canDelete %}
        {% set sourceValue = source.providerName ? 'provider:' ~ source.providerName : 'category:' ~ source.category %}
        {% set count = source.providerName ? (translationCounts.providers[source.providerName] ?? 0) : (translationCounts[source.category] ?? 0) %}
        {% set deleteOptions = deleteOptions|merge([{ value: sourceValue, label: source.label ~ ' Only (' ~ (count|number_format) ~ ')' }]) %}
    {% endif %}
{% endfor %}

{% set formiePluginName = craft.translationManager.getFormiePluginName() %}
{% set hasDeleteOptions = deleteOptions|length > 1 %}

{% if hasDeleteOptions %}
{{ forms.selectField({
    label: "Source to Delete"|t('translation-manager'),
    instructions: "Permanently delete translations for a source or all sources, including generated files."|t('translation-manager'),
    id: 'deleteType',
    name: 'deleteType',
    options: deleteOptions,
    value: ''
}) }}
{% elseif not (enabledFormProviders|length or settings.enableSiteTranslations) %}
<div class="field">
    <div class="heading">
        <label>{{ "Delete Translations"|t('translation-manager') }}</label>
    </div>
    <p class="light">{{ "No translation integrations are currently enabled. Enable {formiePluginName} Integration or Site Translations above to start capturing translations."|t('translation-manager', {formiePluginName: formiePluginName}) }}</p>
</div>
{% endif %}

{% if hasDeleteOptions %}
{% include 'lindemannrock-base/_components/info-box' with {
    message: '',
    type: settings.backupEnabled ? 'warning' : 'error',
    variant: 'colored',
    margin: 'top',
    boxId: 'deleteDescription',
    messageId: 'deleteDescriptionText',
    hidden: true,
    allowHtml: false,
} %}
{% include 'lindemannrock-base/_components/info-box' with {
    message: "No translations found for the selected option."|t('translation-manager'),
    type: 'info',
    variant: 'subtle',
    margin: 'top',
    boxId: 'deleteNoItemsDescription',
    hidden: true,
    allowHtml: false,
} %}

<div style="margin-top: 20px;">
    <button type="button" id="deleteButton" class="btn submit formaction error disabled" style="display: inline-block;" disabled data-redirect="{{ 'translation-manager/maintenance'|hash }}">
        {{ "Delete Selected Source"|t('translation-manager') }}
    </button>
</div>
{% endif %}
{% endif %}
