{% extends "translation-manager/_layouts/cp" %}
{% set title = "Maintenance"|t('translation-manager') %}
{% set fullPageForm = false %}
{% set selectedSubnavItem = 'maintenance' %}

{% set plugin = craft.app.plugins.getPlugin('translation-manager') %}
{% set crumbs = [
    {
        label: translationHelper.fullName|t('translation-manager'),
        url: url('translation-manager'),
    },
    {
        label: 'Maintenance'|t('translation-manager'),
        url: url('translation-manager/maintenance'),
    },
] %}

{% import "_includes/forms" as forms %}
{% set canScan = currentUser.can('translationManager:scanTemplates')
    or (settings.enableFormieIntegration and currentUser.can('translationManager:recaptureFormie')) %}
{% set canCleanup = currentUser.can('translationManager:cleanUnused') %}
{% set canDanger = currentUser.can('translationManager:clearTranslations') %}

{% set tabs = {} %}
{% if canScan %}
    {% set tabs = tabs|merge({
        scan: {
            label: 'Scan'|t('translation-manager'),
            url: '#scan',
        },
    }) %}
{% endif %}
{% if canCleanup %}
    {% set tabs = tabs|merge({
        cleanup: {
            label: 'Cleanup'|t('translation-manager'),
            url: '#cleanup',
        },
    }) %}
{% endif %}
{% if canDanger %}
    {% set tabs = tabs|merge({
        danger: {
            label: 'Danger Zone'|t('translation-manager'),
            url: '#danger',
        },
    }) %}
{% endif %}

{% set selectedTab = canScan ? 'scan' : (canCleanup ? 'cleanup' : 'danger') %}
{% set hashTab = craft.app.request.getParam('tab') ?? craft.app.request.getSegment(4) %}
{% if hashTab in tabs|keys %}
    {% set selectedTab = hashTab %}
{% endif %}
{% set unusedCounts = {
    total: 0,
    site: 0,
    formie: 0,
} %}
{% set languageCleanup = {
    totalCandidates: 0,
    totalRows: 0,
    mappedSource: [],
    ghost: [],
} %}
{% set categoryCleanup = {
    totalCandidates: 0,
    totalRows: 0,
    removed: [],
} %}
{% set translationCounts = {
    total: 0,
    formie: 0,
    site: 0,
} %}
{% if currentUser.can('translationManager:cleanUnused') %}
    {% set unusedCounts = craft.translationManager.getUnusedTranslationCounts() %}
    {% set languageCleanup = craft.translationManager.getLanguageCleanupCandidates() %}
    {% set categoryCleanup = craft.translationManager.getCategoryCleanupCandidates() %}
{% endif %}
{% if canDanger %}
    {% set translationCounts = craft.translationManager.getTranslationCounts() %}
{% endif %}

{% block content %}
    {% if canScan %}
        <div id="scan" class="{{ selectedTab != 'scan' ? 'hidden' }}">
            {% include 'translation-manager/maintenance/_partials/scan' %}
        </div>
    {% endif %}

    {% if canCleanup %}
        <div id="cleanup" class="{{ selectedTab != 'cleanup' ? 'hidden' }}">
            {% include 'translation-manager/maintenance/_partials/cleanup' %}
        </div>
    {% endif %}

    {% if canDanger %}
        <div id="danger" class="{{ selectedTab != 'danger' ? 'hidden' }}">
            {% include 'translation-manager/maintenance/_partials/danger' %}
        </div>
    {% endif %}

{% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% css %}
    #clean-unused-enhanced-btn:disabled,
    #clean-languages-btn:disabled,
    #clean-categories-btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }
{% endcss %}

{% js %}
    // NEW: Handle enhanced unused cleanup dropdown
    const unusedTypeSelect = document.getElementById('unusedType');
    const unusedDescription = document.getElementById('unusedDescription');
    const unusedDescriptionText = document.getElementById('unusedDescriptionText');
    const unusedNoItemsDescription = document.getElementById('unusedNoItemsDescription');
    const cleanUnusedEnhancedBtn = document.getElementById('clean-unused-enhanced-btn');
    const cleanLanguagesBtn = document.getElementById('clean-languages-btn');
    const cleanCategoriesBtn = document.getElementById('clean-categories-btn');
    const cleanLanguageSelect = document.getElementById('cleanLanguage');
    const cleanCategorySelect = document.getElementById('cleanCategory');
    const languageCleanupDescription = document.getElementById('languageCleanupDescription');
    const languageCleanupDescriptionText = document.getElementById('languageCleanupDescriptionText');
    const categoryCleanupDescription = document.getElementById('categoryCleanupDescription');
    const categoryCleanupDescriptionText = document.getElementById('categoryCleanupDescriptionText');

    if (unusedTypeSelect) {
        const cleanupBackupDescriptionSuffix = '{{ settings.backupEnabled ? " A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';
        const descriptions = {
            all: '{{ "This will permanently delete ALL unused translations (both site and form translations) that are no longer used anywhere."|t('translation-manager')|e('js') }}',
            formie: '{{ "This will permanently delete unused form translations from deleted forms or fields."|t('translation-manager')|e('js') }}'
        };
        const counts = {
            all: {{ unusedCounts.total ?? 0 }},
            formie: {{ unusedCounts.formie ?? 0 }},
        };

        // Add dynamic descriptions for each category
        {% for category in settings.getEnabledCategories() %}
        descriptions['category:{{ category }}'] = '{{ "This will permanently delete unused translations for the"|t('translation-manager')|e('js') }} {{ category }} {{ "category that are no longer found in any template files."|t('translation-manager')|e('js') }}';
        counts['category:{{ category }}'] = {{ unusedCounts[category] ?? 0 }};
        {% endfor %}
        if (cleanupBackupDescriptionSuffix) {
            Object.keys(descriptions).forEach((key) => {
                descriptions[key] = descriptions[key] + cleanupBackupDescriptionSuffix;
            });
        }

        unusedTypeSelect.addEventListener('change', function() {
            const value = this.value;
            const selectedCount = counts[value] ?? 0;

            if (value && descriptions[value]) {
                if (unusedNoItemsDescription) {
                    unusedNoItemsDescription.style.display = 'none';
                }
                if (selectedCount > 0) {
                    unusedDescription.style.display = 'block';
                    unusedDescriptionText.textContent = descriptions[value];
                    cleanUnusedEnhancedBtn.classList.remove('disabled');
                    cleanUnusedEnhancedBtn.disabled = false;
                    cleanUnusedEnhancedBtn.setAttribute('data-type', value);
                } else {
                    unusedDescription.style.display = 'none';
                    if (unusedNoItemsDescription) {
                        unusedNoItemsDescription.style.display = 'block';
                    }
                    cleanUnusedEnhancedBtn.classList.add('disabled');
                    cleanUnusedEnhancedBtn.disabled = true;
                    cleanUnusedEnhancedBtn.removeAttribute('data-type');
                }
            } else {
                unusedDescription.style.display = 'none';
                if (unusedNoItemsDescription) {
                    unusedNoItemsDescription.style.display = 'none';
                }
                cleanUnusedEnhancedBtn.classList.add('disabled');
                cleanUnusedEnhancedBtn.disabled = true;
                cleanUnusedEnhancedBtn.removeAttribute('data-type');
            }
        });

        // Handle enhanced clean button click
        cleanUnusedEnhancedBtn.addEventListener('click', function() {
            const type = this.getAttribute('data-type');
            if (!type) return;

            const confirmMessages = {
                all: '{{ "Are you sure you want to delete ALL unused translations?"|t('translation-manager')|e('js') }}',
                formie: '{{ "Are you sure you want to delete unused form translations?"|t('translation-manager')|e('js') }}'
            };

            // Add dynamic confirm messages for each category
            {% for category in settings.getEnabledCategories() %}
            confirmMessages['category:{{ category }}'] = '{{ "Are you sure you want to delete unused"|t('translation-manager')|e('js') }} {{ category }} {{ "translations?"|t('translation-manager')|e('js') }}';
            {% endfor %}

            if (confirm(confirmMessages[type])) {
                const btn = this;
                btn.classList.add('loading');
                btn.disabled = true;

                fetch('{{ actionUrl('translation-manager/maintenance/clean-unused-type') }}', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({type: type})
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Craft.cp.displayNotice(data.message);
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        btn.classList.remove('loading');
                        btn.disabled = false;
                        Craft.cp.displayError(data.error || 'Failed to clean unused translations');
                    }
                })
                .catch(error => {
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    Craft.cp.displayError('Failed to clean unused translations: ' + error.message);
                });
            }
        });
    }

    if (cleanLanguagesBtn && cleanLanguageSelect) {
        const languageCleanupBackupDescriptionSuffix = '{{ settings.backupEnabled ? " A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';
        const languageDescriptions = {
            {% for row in languageCleanup.mappedSource %}
            '{{ row.language }}': '{{ "This will permanently delete all rows for"|t('translation-manager')|e('js') }} {{ row.language }} {{ "(mapped to"|t('translation-manager')|e('js') }} {{ row.mappedTo }}).',
            {% endfor %}
            {% for row in languageCleanup.ghost %}
            '{{ row.language }}': '{{ "This will permanently delete all rows for ghost language"|t('translation-manager')|e('js') }} {{ row.language }}.',
            {% endfor %}
        };
        if (languageCleanupBackupDescriptionSuffix) {
            Object.keys(languageDescriptions).forEach((key) => {
                languageDescriptions[key] = languageDescriptions[key] + languageCleanupBackupDescriptionSuffix;
            });
        }

        function updateCleanLanguagesState() {
            const selected = cleanLanguageSelect.value;
            const hasSelection = !!selected;
            cleanLanguagesBtn.disabled = !hasSelection;
            cleanLanguagesBtn.classList.toggle('disabled', !hasSelection);

            if (hasSelection) {
                const description = languageDescriptions[selected] || (
                    '{{ "This will permanently delete all rows for language"|t('translation-manager')|e('js') }} ' +
                    selected +
                    '.'
                ) + languageCleanupBackupDescriptionSuffix;
                languageCleanupDescription.style.display = 'block';
                languageCleanupDescriptionText.textContent = description;
            } else {
                languageCleanupDescription.style.display = 'none';
            }
        }

        cleanLanguageSelect.addEventListener('change', updateCleanLanguagesState);
        updateCleanLanguagesState();

        cleanLanguagesBtn.addEventListener('click', function() {
            const selected = cleanLanguageSelect.value;
            if (!selected) {
                return;
            }

            if (!confirm(`{{ "Delete all translations for selected language?"|t('translation-manager')|e('js') }}\\n\\n${selected}`)) {
                return;
            }

            const btn = this;
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/clean-languages') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({languages: [selected]})
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message || 'Language cleanup completed');
                    setTimeout(() => window.location.reload(), 1200);
                } else {
                    btn.classList.remove('loading');
                    updateCleanLanguagesState();
                    Craft.cp.displayError(data.error || 'Failed to clean languages');
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                updateCleanLanguagesState();
                Craft.cp.displayError('Failed to clean languages: ' + error.message);
            });
        });
    }

    if (cleanCategoriesBtn && cleanCategorySelect) {
        const categoryCleanupBackupDescriptionSuffix = '{{ settings.backupEnabled ? " A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';
        const categoryDescriptions = {
            {% for row in categoryCleanup.removed %}
            '{{ row.category }}': '{{ "This will permanently delete all rows for removed category"|t('translation-manager')|e('js') }} {{ row.category }}.',
            {% endfor %}
        };
        if (categoryCleanupBackupDescriptionSuffix) {
            Object.keys(categoryDescriptions).forEach((key) => {
                categoryDescriptions[key] = categoryDescriptions[key] + categoryCleanupBackupDescriptionSuffix;
            });
        }

        function updateCleanCategoriesState() {
            const selected = cleanCategorySelect.value;
            const hasSelection = !!selected;
            cleanCategoriesBtn.disabled = !hasSelection;
            cleanCategoriesBtn.classList.toggle('disabled', !hasSelection);

            if (hasSelection) {
                const description = categoryDescriptions[selected] || (
                    '{{ "This will permanently delete all rows for removed category"|t('translation-manager')|e('js') }} ' +
                    selected +
                    '.'
                ) + categoryCleanupBackupDescriptionSuffix;
                categoryCleanupDescription.style.display = 'block';
                categoryCleanupDescriptionText.textContent = description;
            } else {
                categoryCleanupDescription.style.display = 'none';
            }
        }

        cleanCategorySelect.addEventListener('change', updateCleanCategoriesState);
        updateCleanCategoriesState();

        cleanCategoriesBtn.addEventListener('click', function() {
            const selected = cleanCategorySelect.value;
            if (!selected) {
                return;
            }

            if (!confirm(`{{ "Delete all translations for selected removed category?"|t('translation-manager')|e('js') }}\\n\\n${selected}`)) {
                return;
            }

            const btn = this;
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/clean-categories') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({categories: [selected]})
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message || 'Category cleanup completed');
                    setTimeout(() => window.location.reload(), 1200);
                } else {
                    btn.classList.remove('loading');
                    updateCleanCategoriesState();
                    Craft.cp.displayError(data.error || 'Failed to clean categories');
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                updateCleanCategoriesState();
                Craft.cp.displayError('Failed to clean categories: ' + error.message);
            });
        });
    }

    // Handle both scan templates buttons
    const scanTemplatesBtn = document.getElementById('scan-templates-btn');
    const rescanTemplatesBtn = document.getElementById('rescan-templates-btn');

    function handleTemplateScan(btn) {
        btn.addEventListener('click', function() {
            const button = this;
            button.classList.add('loading');
            button.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/scan-templates-action') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({})
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message);
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    button.classList.remove('loading');
                    button.disabled = false;
                    Craft.cp.displayError(data.error || 'Failed to scan templates');
                }
            })
            .catch(error => {
                button.classList.remove('loading');
                button.disabled = false;
                Craft.cp.displayError('Failed to scan templates: ' + error.message);
            });
        });
    }

    // Apply to both buttons
    if (scanTemplatesBtn) {
        handleTemplateScan(scanTemplatesBtn);
    }
    if (rescanTemplatesBtn) {
        handleTemplateScan(rescanTemplatesBtn);
    }

    // Handle recapture Formie button
    const recaptureFormieBtn = document.getElementById('recapture-formie-btn');
    if (recaptureFormieBtn) {
        recaptureFormieBtn.addEventListener('click', function() {
            const btn = this;
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/recapture-formie') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({})
            })
            .then(response => response.json())
            .then(data => {
                btn.classList.remove('loading');
                btn.disabled = false;
                if (data.success) {
                    Craft.cp.displayNotice(data.message);
                } else {
                    Craft.cp.displayError(data.error || 'Failed to recapture form translations');
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                btn.disabled = false;
                Craft.cp.displayError('Failed to recapture form translations: ' + error.message);
            });
        });
    }

    // Handle clean unused button (original)
    const cleanUnusedBtn = document.getElementById('clean-unused-btn');
    if (cleanUnusedBtn && !cleanUnusedBtn.disabled) {
        cleanUnusedBtn.addEventListener('click', function() {
            if (confirm('{{ "Are you sure you want to remove all unused form translations?"|t('translation-manager')|e('js') }}')) {
                const btn = this;
                btn.classList.add('loading');
                btn.disabled = true;

                fetch('{{ actionUrl('translation-manager/maintenance/clean-unused') }}', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({})
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Show success message
                        Craft.cp.displayNotice(data.message);
                        // Reload after a short delay to show the message
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        btn.classList.remove('loading');
                        btn.disabled = false;
                        Craft.cp.displayError(data.error || 'Failed to clean unused translations');
                    }
                })
                .catch(error => {
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    Craft.cp.displayError('Failed to clean unused translations: ' + error.message);
                });
            }
        });
    }

    // Handle danger zone clear type selection
    const clearTypeSelect = document.getElementById('clearType');
    const clearDescription = document.getElementById('clearDescription');
    const clearDescriptionText = document.getElementById('clearDescriptionText');
    const clearNoItemsDescription = document.getElementById('clearNoItemsDescription');
    const clearButton = document.getElementById('clearButton');

    if (clearTypeSelect) {
        const hasFormie = {{ settings.enableFormieIntegration ? 'true' : 'false' }};
        const hasSite = {{ settings.enableSiteTranslations ? 'true' : 'false' }};
        const formiePluginName = '{{ craft.translationManager.getFormiePluginName()|e('js') }}';
        const backupDescriptionSuffix = '{{ settings.backupEnabled ? " A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';

        let allDescription = '{{ "This will permanently delete ALL translations from the database and remove all translation files. Use this to start completely fresh."|t('translation-manager')|e('js') }}';
        if (hasFormie && hasSite) {
            allDescription = '{{ "This will permanently delete ALL translations from the database and remove all translation files, including both "|t('translation-manager')|e('js') }}' + formiePluginName + '{{ " and site translations. Use this to start completely fresh."|t('translation-manager')|e('js') }}';
        }

        const descriptions = {
            formie: '{{ "This will permanently delete all "|t('translation-manager')|e('js') }}' + formiePluginName + '{{ " form translations from the database and remove the corresponding translation files. Your forms will not be affected, only the stored translations will be removed."|t('translation-manager')|e('js') }}',
            all: allDescription
        };
        const counts = {
            formie: {{ translationCounts.formie ?? 0 }},
            all: {{ translationCounts.total ?? 0 }}
        };

        // Add dynamic descriptions for each category
        {% for category in settings.getEnabledCategories() %}
        descriptions['category:{{ category }}'] = '{{ "This will permanently delete all translations for the"|t('translation-manager')|e('js') }} {{ category }} {{ "category from the database and remove the corresponding translation files. You will need to re-translate this content."|t('translation-manager')|e('js') }}';
        counts['category:{{ category }}'] = {{ translationCounts[category] ?? 0 }};
        {% endfor %}

        if (backupDescriptionSuffix) {
            Object.keys(descriptions).forEach((key) => {
                descriptions[key] = descriptions[key] + backupDescriptionSuffix;
            });
        }

        const confirmMessages = {
            formie: '{{ "Are you sure you want to delete all "|t('translation-manager')|e('js') }}' + formiePluginName + '{{ " translations and their files? This action cannot be undone."|t('translation-manager')|e('js') }}',
            all: '{{ "Are you absolutely sure you want to delete ALL translations and files? This will remove both "|t('translation-manager')|e('js') }}' + formiePluginName + '{{ " and site translations. This action cannot be undone."|t('translation-manager')|e('js') }}'
        };

        // Add dynamic confirm messages for each category
        {% for category in settings.getEnabledCategories() %}
        confirmMessages['category:{{ category }}'] = '{{ "Are you sure you want to delete all"|t('translation-manager')|e('js') }} {{ category }} {{ "translations and their files? This action cannot be undone."|t('translation-manager')|e('js') }}';
        {% endfor %}

        const actions = {
            formie: 'translation-manager/settings/clear-formie',
            all: 'translation-manager/settings/clear-all'
        };

        // Add dynamic actions for each category
        {% for category in settings.getEnabledCategories() %}
        actions['category:{{ category }}'] = 'translation-manager/settings/clear-category';
        {% endfor %}

        clearTypeSelect.addEventListener('change', function() {
            const value = this.value;
            const selectedCount = counts[value] ?? 0;
            if (clearNoItemsDescription) {
                clearNoItemsDescription.style.display = 'none';
            }

            if (value) {
                if (selectedCount > 0) {
                    clearDescription.style.display = 'block';
                    clearDescriptionText.textContent = descriptions[value];
                    clearButton.disabled = false;
                    clearButton.classList.remove('disabled');
                    clearButton.setAttribute('data-action', actions[value]);
                    clearButton.setAttribute('data-confirm', confirmMessages[value]);
                } else {
                    clearDescription.style.display = 'none';
                    clearButton.disabled = true;
                    clearButton.classList.add('disabled');
                    if (clearNoItemsDescription) {
                        clearNoItemsDescription.style.display = 'block';
                    }
                }
            } else {
                clearDescription.style.display = 'none';
                clearButton.disabled = true;
                clearButton.classList.add('disabled');
                if (clearNoItemsDescription) {
                    clearNoItemsDescription.style.display = 'none';
                }
            }
        });

        // Handle clear button click
        clearButton.addEventListener('click', function() {
            const action = this.getAttribute('data-action');
            const confirmMessage = this.getAttribute('data-confirm');
            const selectedValue = clearTypeSelect.value;

            if (action) {
                {% if settings.backupEnabled %}
                // Add backup notice to confirmation for dangerous actions
                const backupNotice = '\n\n{{ "Note: A backup will be created automatically before deleting."|t('translation-manager')|e('js') }}';
                const fullMessage = confirmMessage + backupNotice;
                {% else %}
                const fullMessage = confirmMessage;
                {% endif %}

                if (!confirm(fullMessage)) {
                    return;
                }
                // Create a form and submit it
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '';
                form.style.display = 'none';

                // Add CSRF token
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = '{{ craft.app.config.general.csrfTokenName }}';
                csrfInput.value = '{{ craft.app.request.csrfToken }}';
                form.appendChild(csrfInput);

                // Add action input
                const actionInput = document.createElement('input');
                actionInput.type = 'hidden';
                actionInput.name = 'action';
                actionInput.value = action;
                form.appendChild(actionInput);

                // Add category input if this is a per-category clear
                if (selectedValue.startsWith('category:')) {
                    const categoryInput = document.createElement('input');
                    categoryInput.type = 'hidden';
                    categoryInput.name = 'category';
                    categoryInput.value = selectedValue.substring(9); // Remove 'category:' prefix
                    form.appendChild(categoryInput);
                }

                // Add redirect input with proper hash
                const redirectInput = document.createElement('input');
                redirectInput.type = 'hidden';
                redirectInput.name = 'redirect';
                redirectInput.value = '{{ 'translation-manager/maintenance'|hash }}';
                form.appendChild(redirectInput);

                // Submit form
                document.body.appendChild(form);
                form.submit();
            }
        });
    }
{% endjs %}
