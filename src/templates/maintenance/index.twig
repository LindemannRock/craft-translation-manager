{% extends "translation-manager/_layouts/cp" %}
{% set title = "Maintenance"|t('translation-manager') %}
{% set fullPageForm = false %}
{% set selectedSubnavItem = 'maintenance' %}

{% set plugin = craft.app.plugins.getPlugin('translation-manager') %}
{% set crumbs = [
    {
        label: translationHelper.fullName|t('translation-manager'),
        url: url('translation-manager'),
    },
    {
        label: 'Maintenance'|t('translation-manager'),
        url: url('translation-manager/maintenance'),
    },
] %}

{% import "_includes/forms" as forms %}
{% set formProviders = craft.translationManager.getFormProviders() %}
{% set enabledFormProviders = craft.translationManager.getEnabledFormProviders() %}
{% set capturableFormProviders = [] %}
{% for provider in enabledFormProviders %}
    {% if provider.available and provider.canCapture %}
        {% set capturableFormProviders = capturableFormProviders|merge([provider]) %}
    {% endif %}
{% endfor %}
{% set canScan = craft.translationManager.canCaptureAllSources()
    or craft.translationManager.getSources()|filter(source => source.type == 'category' and source.canCapture)|length
    or capturableFormProviders|length %}
{% set deletableUnusedSources = craft.translationManager.getSources()|filter(source => source.canDeleteUnused) %}
{% set canDeleteAnyUnusedTranslations = craft.translationManager.canDeleteAllUnusedTranslations() or deletableUnusedSources|length %}
{% set canCleanup = canDeleteAnyUnusedTranslations or currentUser.can('translationManager:cleanMaintenanceArtifacts') %}
{% set canDeleteTranslations = craft.translationManager.canDeleteAllSources()
    or craft.translationManager.getSources()|filter(source => source.canDelete)|length %}

{% set tabs = {} %}
{% if canScan %}
    {% set tabs = tabs|merge({
        scan: {
            label: 'Capture'|t('translation-manager'),
            url: '#scan',
        },
    }) %}
{% endif %}
{% if canCleanup %}
    {% set tabs = tabs|merge({
        cleanup: {
            label: 'Cleanup'|t('translation-manager'),
            url: '#cleanup',
        },
    }) %}
{% endif %}
{% if canDeleteTranslations %}
    {% set tabs = tabs|merge({
        danger: {
            label: 'Danger'|t('translation-manager'),
            url: '#danger',
        },
    }) %}
{% endif %}

{% set hasMaintenanceActions = canScan or canCleanup or canDeleteTranslations %}
{% set selectedTab = canScan ? 'scan' : (canCleanup ? 'cleanup' : (canDeleteTranslations ? 'danger' : '')) %}
{% set hashTab = craft.app.request.getParam('tab') ?? craft.app.request.getSegment(4) %}
{% if hashTab in tabs|keys %}
    {% set selectedTab = hashTab %}
{% endif %}
{% set unusedCounts = {
    total: 0,
    site: 0,
    forms: 0,
    providers: {},
} %}
{% set languageCleanup = {
    totalCandidates: 0,
    totalRows: 0,
    mappedSource: [],
    ghost: [],
} %}
{% set categoryCleanup = {
    totalCandidates: 0,
    totalRows: 0,
    removed: [],
} %}
{% set generatedFileCleanup = {
    totalCandidates: 0,
    files: [],
} %}
{% set translationCounts = {
    total: 0,
    site: 0,
    providers: {},
} %}
{% if canCleanup %}
    {% set unusedCounts = craft.translationManager.getUnusedTranslationCounts() %}
    {% set languageCleanup = craft.translationManager.getLanguageCleanupCandidates() %}
    {% set categoryCleanup = craft.translationManager.getCategoryCleanupCandidates() %}
    {% set generatedFileCleanup = craft.translationManager.getGeneratedFileCleanupCandidates() %}
{% endif %}
{% if canDeleteTranslations %}
    {% set translationCounts = craft.translationManager.getTranslationCounts() %}
{% endif %}

{% block content %}
    {% if not hasMaintenanceActions %}
        {% include 'lindemannrock-base/_components/info-box' with {
            message: 'You can view this section, but no maintenance actions are available for your account. Ask an administrator to grant Capture translations, Clean artifacts, or Delete unused translations for at least one translation source.'|t('translation-manager'),
        } %}
    {% endif %}

    {% if canScan %}
        <div id="scan" class="{{ selectedTab != 'scan' ? 'hidden' }}">
            {% include 'translation-manager/maintenance/_partials/scan' %}
        </div>
    {% endif %}

    {% if canCleanup %}
        <div id="cleanup" class="{{ selectedTab != 'cleanup' ? 'hidden' }}">
            {% include 'translation-manager/maintenance/_partials/cleanup' %}
        </div>
    {% endif %}

    {% if canDeleteTranslations %}
        <div id="danger" class="{{ selectedTab != 'danger' ? 'hidden' }}">
            {% include 'translation-manager/maintenance/_partials/danger' %}
        </div>
    {% endif %}

{% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% css %}
    #clean-unused-enhanced-btn:disabled,
    #migrate-clean-languages-btn:disabled,
    #clean-languages-btn:disabled,
    #clean-categories-btn:disabled,
    #clean-generated-file-btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }
{% endcss %}

{% js %}
    // NEW: Handle enhanced unused cleanup dropdown
    const unusedTypeSelect = document.getElementById('unusedType');
    const unusedDescription = document.getElementById('unusedDescription');
    const unusedDescriptionText = document.getElementById('unusedDescriptionText');
    const unusedNoItemsDescription = document.getElementById('unusedNoItemsDescription');
    const cleanUnusedEnhancedBtn = document.getElementById('clean-unused-enhanced-btn');
    const cleanLanguagesBtn = document.getElementById('clean-languages-btn');
    const migrateCleanLanguagesBtn = document.getElementById('migrate-clean-languages-btn');
    const cleanCategoriesBtn = document.getElementById('clean-categories-btn');
    const cleanLanguageSelect = document.getElementById('cleanLanguage');
    const cleanCategorySelect = document.getElementById('cleanCategory');
    const cleanGeneratedFileSelect = document.getElementById('cleanGeneratedFile');
    const languageCleanupDescription = document.getElementById('languageCleanupDescription');
    const languageCleanupDescriptionText = document.getElementById('languageCleanupDescriptionText');
    const categoryCleanupDescription = document.getElementById('categoryCleanupDescription');
    const categoryCleanupDescriptionText = document.getElementById('categoryCleanupDescriptionText');
    const generatedFileCleanupDescription = document.getElementById('generatedFileCleanupDescription');
    const generatedFileCleanupDescriptionText = document.getElementById('generatedFileCleanupDescriptionText');
    const cleanGeneratedFileBtn = document.getElementById('clean-generated-file-btn');

    function withBackupDescription(message, backupSuffix) {
        return backupSuffix ? `${message} ${backupSuffix}` : message;
    }

    if (unusedTypeSelect) {
        const cleanupBackupDescriptionSuffix = '{{ settings.backupEnabled ? "A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';
        const descriptions = {
            all: '{{ "This will permanently delete ALL unused translations (both site and form translations) that are no longer used anywhere."|t('translation-manager')|e('js') }}'
        };
        const counts = {
            all: {{ unusedCounts.total ?? 0 }}
        };

        {% for provider in enabledFormProviders %}
        descriptions['provider:{{ provider.name|e('js') }}'] = '{{ "This will permanently delete unused form translations from deleted forms or fields."|t('translation-manager')|e('js') }}';
        counts['provider:{{ provider.name|e('js') }}'] = {{ unusedCounts.providers[provider.name] ?? 0 }};
        {% endfor %}

        // Add dynamic descriptions for each category
        {% for category in settings.getEnabledCategories() %}
        descriptions['category:{{ category|e('js') }}'] = '{{ "This will permanently delete unused translations for the {category} category that are no longer found in any template files."|t('translation-manager', {category: category})|e('js') }}';
        counts['category:{{ category|e('js') }}'] = {{ unusedCounts[category] ?? 0 }};
        {% endfor %}
        if (cleanupBackupDescriptionSuffix) {
            Object.keys(descriptions).forEach((key) => {
                descriptions[key] = withBackupDescription(descriptions[key], cleanupBackupDescriptionSuffix);
            });
        }

        unusedTypeSelect.addEventListener('change', function() {
            const value = this.value;
            const selectedCount = counts[value] ?? 0;

            if (value && descriptions[value]) {
                if (unusedNoItemsDescription) {
                    unusedNoItemsDescription.style.display = 'none';
                }
                if (selectedCount > 0) {
                    unusedDescription.style.display = 'block';
                    unusedDescriptionText.textContent = descriptions[value];
                    cleanUnusedEnhancedBtn.classList.remove('disabled');
                    cleanUnusedEnhancedBtn.disabled = false;
                    cleanUnusedEnhancedBtn.setAttribute('data-type', value);
                } else {
                    unusedDescription.style.display = 'none';
                    if (unusedNoItemsDescription) {
                        unusedNoItemsDescription.style.display = 'block';
                    }
                    cleanUnusedEnhancedBtn.classList.add('disabled');
                    cleanUnusedEnhancedBtn.disabled = true;
                    cleanUnusedEnhancedBtn.removeAttribute('data-type');
                }
            } else {
                unusedDescription.style.display = 'none';
                if (unusedNoItemsDescription) {
                    unusedNoItemsDescription.style.display = 'none';
                }
                cleanUnusedEnhancedBtn.classList.add('disabled');
                cleanUnusedEnhancedBtn.disabled = true;
                cleanUnusedEnhancedBtn.removeAttribute('data-type');
            }
        });

        // Handle enhanced clean button click
        cleanUnusedEnhancedBtn.addEventListener('click', function() {
            const type = this.getAttribute('data-type');
            if (!type) return;

            const confirmMessages = {
                all: '{{ "Are you sure you want to delete ALL unused translations?"|t('translation-manager')|e('js') }}'
            };

            {% for provider in enabledFormProviders %}
            confirmMessages['provider:{{ provider.name|e('js') }}'] = '{{ "Are you sure you want to delete unused form translations?"|t('translation-manager')|e('js') }}';
            {% endfor %}

            // Add dynamic confirm messages for each category
            {% for category in settings.getEnabledCategories() %}
            confirmMessages['category:{{ category|e('js') }}'] = '{{ "Are you sure you want to delete unused {category} translations?"|t('translation-manager', {category: category})|e('js') }}';
            {% endfor %}

            if (confirm(confirmMessages[type])) {
                const btn = this;
                btn.classList.add('loading');
                btn.disabled = true;

                fetch('{{ actionUrl('translation-manager/maintenance/clean-unused-type') }}', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({type: type})
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Craft.cp.displayNotice(data.message);
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        btn.classList.remove('loading');
                        btn.disabled = false;
                        Craft.cp.displayError(data.error || {{ 'Failed to clean unused translations'|t('translation-manager')|json_encode|raw }});
                    }
                })
                .catch(error => {
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    Craft.cp.displayError({{ 'Failed to clean unused translations: {error}'|t('translation-manager')|json_encode|raw }}.replace('{error}', error.message));
                });
            }
        });
    }

    if (cleanLanguagesBtn && cleanLanguageSelect) {
        const languageCleanupBackupDescriptionSuffix = '{{ settings.backupEnabled ? "A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';
        const mappedSourceLanguages = new Set([
            {% for row in languageCleanup.mappedSource %}
            '{{ row.language|e('js') }}',
            {% endfor %}
        ]);
        const mappedLanguageTargets = {
            {% for row in languageCleanup.mappedSource %}
            '{{ row.language|e('js') }}': '{{ row.mappedTo|e('js') }}',
            {% endfor %}
        };
        const languageDescriptions = {
            {% for row in languageCleanup.mappedSource %}
            '{{ row.language|e('js') }}': '{{ "Migrate & Delete copies useful translations into the mapped target without overwriting existing translations, then deletes the mapped-source rows. Delete Only permanently removes the mapped-source rows without copying."|t('translation-manager')|e('js') }}',
            {% endfor %}
            {% for row in languageCleanup.ghost %}
            '{{ row.language|e('js') }}': '{{ "This will permanently delete all rows for ghost language {language}."|t('translation-manager', {language: row.language})|e('js') }}',
            {% endfor %}
        };
        if (languageCleanupBackupDescriptionSuffix) {
            Object.keys(languageDescriptions).forEach((key) => {
                languageDescriptions[key] = withBackupDescription(languageDescriptions[key], languageCleanupBackupDescriptionSuffix);
            });
        }

        function updateCleanLanguagesState() {
            const selected = cleanLanguageSelect.value;
            const hasSelection = !!selected;
            const isMappedSource = mappedSourceLanguages.has(selected);
            cleanLanguagesBtn.disabled = !hasSelection;
            cleanLanguagesBtn.classList.toggle('disabled', !hasSelection);
            if (migrateCleanLanguagesBtn) {
                migrateCleanLanguagesBtn.disabled = !hasSelection || !isMappedSource;
                migrateCleanLanguagesBtn.classList.toggle('disabled', !hasSelection || !isMappedSource);
                migrateCleanLanguagesBtn.style.display = isMappedSource ? 'inline-block' : 'none';
            }

            if (hasSelection) {
                const description = languageDescriptions[selected] || (
                    `{{ "This will permanently delete all rows for language {language}."|t('translation-manager', {language: '__LANGUAGE__'})|e('js') }}`
                        .replaceAll('__LANGUAGE__', selected)
                );
                languageCleanupDescription.style.display = 'block';
                languageCleanupDescriptionText.textContent = withBackupDescription(description, languageCleanupBackupDescriptionSuffix);
            } else {
                languageCleanupDescription.style.display = 'none';
            }
        }

        cleanLanguageSelect.addEventListener('change', updateCleanLanguagesState);
        updateCleanLanguagesState();

        function runLanguageCleanup(mode, btn) {
            const selected = cleanLanguageSelect.value;
            if (!selected) {
                return;
            }

            const target = mappedLanguageTargets[selected] || '';
            const confirmMessage = mode === 'migrate' && target
                ? `{{ "Migrate useful {source} translations into {target}, then delete {source} rows?"|t('translation-manager', {source: '__SOURCE__', target: '__TARGET__'})|e('js') }}`
                    .replaceAll('__SOURCE__', selected)
                    .replaceAll('__TARGET__', target)
                : `{{ "Delete all translations for selected language without copying?"|t('translation-manager')|e('js') }}\n\n${selected}`;
            if (!confirm(confirmMessage)) {
                return;
            }

            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/clean-languages') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({languages: [selected], mode})
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message || {{ 'Language cleanup completed'|t('translation-manager')|json_encode|raw }});
                    setTimeout(() => window.location.reload(), 1200);
                } else {
                    btn.classList.remove('loading');
                    updateCleanLanguagesState();
                    Craft.cp.displayError(data.error || {{ 'Failed to clean languages'|t('translation-manager')|json_encode|raw }});
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                updateCleanLanguagesState();
                Craft.cp.displayError({{ 'Failed to clean languages: {error}'|t('translation-manager')|json_encode|raw }}.replace('{error}', error.message));
            });
        }

        cleanLanguagesBtn.addEventListener('click', function() {
            runLanguageCleanup('delete', this);
        });
        migrateCleanLanguagesBtn?.addEventListener('click', function() {
            runLanguageCleanup('migrate', this);
        });
    }

    if (cleanCategoriesBtn && cleanCategorySelect) {
        const categoryCleanupBackupDescriptionSuffix = '{{ settings.backupEnabled ? "A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';
        const categoryDescriptions = {
            {% for row in categoryCleanup.removed %}
            '{{ row.category|e('js') }}': '{{ "This will permanently delete all rows for removed category {category}."|t('translation-manager', {category: row.category})|e('js') }}',
            {% endfor %}
        };
        if (categoryCleanupBackupDescriptionSuffix) {
            Object.keys(categoryDescriptions).forEach((key) => {
                categoryDescriptions[key] = withBackupDescription(categoryDescriptions[key], categoryCleanupBackupDescriptionSuffix);
            });
        }

        function updateCleanCategoriesState() {
            const selected = cleanCategorySelect.value;
            const hasSelection = !!selected;
            cleanCategoriesBtn.disabled = !hasSelection;
            cleanCategoriesBtn.classList.toggle('disabled', !hasSelection);

            if (hasSelection) {
                const description = categoryDescriptions[selected] || (
                    `{{ "This will permanently delete all rows for removed category {category}."|t('translation-manager', {category: '__CATEGORY__'})|e('js') }}`
                        .replaceAll('__CATEGORY__', selected)
                );
                categoryCleanupDescription.style.display = 'block';
                categoryCleanupDescriptionText.textContent = withBackupDescription(description, categoryCleanupBackupDescriptionSuffix);
            } else {
                categoryCleanupDescription.style.display = 'none';
            }
        }

        cleanCategorySelect.addEventListener('change', updateCleanCategoriesState);
        updateCleanCategoriesState();

        cleanCategoriesBtn.addEventListener('click', function() {
            const selected = cleanCategorySelect.value;
            if (!selected) {
                return;
            }

            if (!confirm(`{{ "Delete all translations for selected removed category?"|t('translation-manager')|e('js') }}\\n\\n${selected}`)) {
                return;
            }

            const btn = this;
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/clean-categories') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({categories: [selected]})
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message || {{ 'Category cleanup completed'|t('translation-manager')|json_encode|raw }});
                    setTimeout(() => window.location.reload(), 1200);
                } else {
                    btn.classList.remove('loading');
                    updateCleanCategoriesState();
                    Craft.cp.displayError(data.error || {{ 'Failed to clean categories'|t('translation-manager')|json_encode|raw }});
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                updateCleanCategoriesState();
                Craft.cp.displayError({{ 'Failed to clean categories: {error}'|t('translation-manager')|json_encode|raw }}.replace('{error}', error.message));
            });
        });
    }

    if (cleanGeneratedFileBtn && cleanGeneratedFileSelect) {
        const generatedFileDescriptions = {
            {% for row in generatedFileCleanup.files %}
            '{{ row.path|e('js') }}': '{{ "This will permanently delete the generated PHP file {file}. Database translation rows are not changed."|t('translation-manager', {file: row.path})|e('js') }}',
            {% endfor %}
        };

        function updateCleanGeneratedFileState() {
            const selected = cleanGeneratedFileSelect.value;
            const hasSelection = !!selected;
            cleanGeneratedFileBtn.disabled = !hasSelection;
            cleanGeneratedFileBtn.classList.toggle('disabled', !hasSelection);

            if (hasSelection) {
                generatedFileCleanupDescription.style.display = 'block';
                generatedFileCleanupDescriptionText.textContent = generatedFileDescriptions[selected] || (
                    `{{ "This will permanently delete the selected generated PHP file. Database translation rows are not changed."|t('translation-manager')|e('js') }}`
                );
            } else {
                generatedFileCleanupDescription.style.display = 'none';
            }
        }

        cleanGeneratedFileSelect.addEventListener('change', updateCleanGeneratedFileState);
        updateCleanGeneratedFileState();

        cleanGeneratedFileBtn.addEventListener('click', function() {
            const selected = cleanGeneratedFileSelect.value;
            if (!selected) {
                return;
            }

            if (!confirm(`{{ "Delete selected generated PHP file?"|t('translation-manager')|e('js') }}\\n\\n${selected}`)) {
                return;
            }

            const btn = this;
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/clean-generated-file') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({path: selected})
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message || {{ 'Generated file cleanup completed.'|t('translation-manager')|json_encode|raw }});
                    setTimeout(() => window.location.reload(), 1200);
                } else {
                    btn.classList.remove('loading');
                    updateCleanGeneratedFileState();
                    Craft.cp.displayError(data.error || {{ 'Failed to clean generated file.'|t('translation-manager')|json_encode|raw }});
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                updateCleanGeneratedFileState();
                Craft.cp.displayError({{ 'Failed to clean generated file: {error}'|t('translation-manager')|json_encode|raw }}.replace('{error}', error.message));
            });
        });
    }

    const captureTemplateSelect = document.getElementById('captureTemplateCategory');
    const captureTemplateBtn = document.getElementById('capture-template-btn');

    function updateCaptureTemplateState() {
        if (!captureTemplateSelect || !captureTemplateBtn) {
            return;
        }
        const hasSelection = captureTemplateSelect.value !== '';
        captureTemplateBtn.disabled = !hasSelection;
        captureTemplateBtn.classList.toggle('disabled', !hasSelection);
    }

    if (captureTemplateSelect && captureTemplateBtn) {
        captureTemplateSelect.addEventListener('change', updateCaptureTemplateState);
        updateCaptureTemplateState();

        captureTemplateBtn.addEventListener('click', function() {
            const selected = captureTemplateSelect.value;
            if (!selected) {
                return;
            }

            const btn = this;
            const body = selected === 'all' ? {} : {category: selected};
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/scan-templates-action') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(body)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Craft.cp.displayNotice(data.message);
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    btn.classList.remove('loading');
                    updateCaptureTemplateState();
                    Craft.cp.displayError(data.error || {{ 'Failed to capture template translations'|t('translation-manager')|json_encode|raw }});
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                updateCaptureTemplateState();
                Craft.cp.displayError({{ 'Failed to capture template translations: {error}'|t('translation-manager')|json_encode|raw }}.replace('{error}', error.message));
            });
        });
    }

    const captureProviderSelect = document.getElementById('captureFormProvider');
    const captureProviderBtn = document.getElementById('capture-provider-btn');

    function updateCaptureProviderState() {
        if (!captureProviderSelect || !captureProviderBtn) {
            return;
        }
        const hasSelection = captureProviderSelect.value !== '';
        captureProviderBtn.disabled = !hasSelection;
        captureProviderBtn.classList.toggle('disabled', !hasSelection);
    }

    if (captureProviderSelect && captureProviderBtn) {
        captureProviderSelect.addEventListener('change', updateCaptureProviderState);
        updateCaptureProviderState();

        captureProviderBtn.addEventListener('click', function() {
            const provider = captureProviderSelect.value;
            if (!provider) {
                return;
            }

            const btn = this;
            btn.classList.add('loading');
            btn.disabled = true;

            fetch('{{ actionUrl('translation-manager/maintenance/capture-provider') }}', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({provider: provider})
            })
            .then(response => response.json())
            .then(data => {
                btn.classList.remove('loading');
                btn.disabled = false;
                if (data.success) {
                    Craft.cp.displayNotice(data.message);
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    updateCaptureProviderState();
                    Craft.cp.displayError(data.error || {{ 'Failed to capture form translations'|t('translation-manager')|json_encode|raw }});
                }
            })
            .catch(error => {
                btn.classList.remove('loading');
                updateCaptureProviderState();
                Craft.cp.displayError({{ 'Failed to capture form translations: {error}'|t('translation-manager')|json_encode|raw }}.replace('{error}', error.message));
            });
        });
    }

    // Handle clean unused button (original)
    const cleanUnusedBtn = document.getElementById('clean-unused-btn');
    if (cleanUnusedBtn && !cleanUnusedBtn.disabled) {
        cleanUnusedBtn.addEventListener('click', function() {
            if (confirm('{{ "Are you sure you want to remove all unused form translations?"|t('translation-manager')|e('js') }}')) {
                const btn = this;
                btn.classList.add('loading');
                btn.disabled = true;

                fetch('{{ actionUrl('translation-manager/maintenance/clean-unused') }}', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '{{ craft.app.request.csrfToken }}',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({})
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Show success message
                        Craft.cp.displayNotice(data.message);
                        // Reload after a short delay to show the message
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        btn.classList.remove('loading');
                        btn.disabled = false;
                        Craft.cp.displayError(data.error || {{ 'Failed to clean unused translations'|t('translation-manager')|json_encode|raw }});
                    }
                })
                .catch(error => {
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    Craft.cp.displayError({{ 'Failed to clean unused translations: {error}'|t('translation-manager')|json_encode|raw }}.replace('{error}', error.message));
                });
            }
        });
    }

    // Handle source deletion selection
    const deleteTypeSelect = document.getElementById('deleteType');
    const deleteDescription = document.getElementById('deleteDescription');
    const deleteDescriptionText = document.getElementById('deleteDescriptionText');
    const deleteNoItemsDescription = document.getElementById('deleteNoItemsDescription');
    const deleteButton = document.getElementById('deleteButton');

    if (deleteTypeSelect) {
        const hasSite = {{ settings.enableSiteTranslations ? 'true' : 'false' }};
        const hasForms = {{ enabledFormProviders|length ? 'true' : 'false' }};
        const formTranslationsName = '{{ "Forms"|t('translation-manager')|e('js') }}';
        const backupDescriptionSuffix = '{{ settings.backupEnabled ? "A backup will be created automatically before deleting."|t('translation-manager')|e('js') : '' }}';

        let allDescription = '{{ "This will permanently delete ALL translations from the database and remove all translation files. Use this to start completely fresh."|t('translation-manager')|e('js') }}';
        if (hasForms && hasSite) {
            allDescription = `{{ "This will permanently delete ALL translations from the database and remove all translation files, including both {name} and site translations. Use this to start completely fresh."|t('translation-manager', {name: '__NAME__'})|e('js') }}`
                .replaceAll('__NAME__', formTranslationsName);
        }

        const descriptions = {
            all: allDescription
        };
        const counts = {
            all: {{ translationCounts.total ?? 0 }}
        };

        {% for provider in enabledFormProviders %}
        descriptions['provider:{{ provider.name|e('js') }}'] = `{{ "This will permanently delete all {name} form translations from the database and remove the corresponding translation files. Your forms will not be affected, only the stored translations will be removed."|t('translation-manager', {name: '__NAME__'})|e('js') }}`
            .replaceAll('__NAME__', '{{ provider.label|e('js') }}');
        counts['provider:{{ provider.name|e('js') }}'] = {{ translationCounts.providers[provider.name] ?? 0 }};
        {% endfor %}

        // Add dynamic descriptions for each category
        {% for category in settings.getEnabledCategories() %}
        descriptions['category:{{ category|e('js') }}'] = '{{ "This will permanently delete all translations for the {category} category from the database and remove the corresponding translation files. You will need to re-translate this content."|t('translation-manager', {category: category})|e('js') }}';
        counts['category:{{ category|e('js') }}'] = {{ translationCounts[category] ?? 0 }};
        {% endfor %}

        if (backupDescriptionSuffix) {
            Object.keys(descriptions).forEach((key) => {
                descriptions[key] = withBackupDescription(descriptions[key], backupDescriptionSuffix);
            });
        }

        const confirmMessages = {
            all: `{{ "Are you absolutely sure you want to delete ALL translations and files? This will remove both {name} and site translations. This action cannot be undone."|t('translation-manager', {name: '__NAME__'})|e('js') }}`
                .replaceAll('__NAME__', formTranslationsName)
        };

        {% for provider in enabledFormProviders %}
        confirmMessages['provider:{{ provider.name|e('js') }}'] = `{{ "Are you sure you want to delete all {name} translations and their files? This action cannot be undone."|t('translation-manager', {name: '__NAME__'})|e('js') }}`
            .replaceAll('__NAME__', '{{ provider.label|e('js') }}');
        {% endfor %}

        // Add dynamic confirm messages for each category
        {% for category in settings.getEnabledCategories() %}
        confirmMessages['category:{{ category|e('js') }}'] = '{{ "Are you sure you want to delete all {name} translations and their files? This action cannot be undone."|t('translation-manager', {name: category})|e('js') }}';
        {% endfor %}

        const actions = {
            all: 'translation-manager/settings/delete-all'
        };

        {% for provider in enabledFormProviders %}
        actions['provider:{{ provider.name|e('js') }}'] = 'translation-manager/settings/delete-provider';
        {% endfor %}

        // Add dynamic actions for each category
        {% for category in settings.getEnabledCategories() %}
        actions['category:{{ category }}'] = 'translation-manager/settings/delete-category';
        {% endfor %}

        deleteTypeSelect.addEventListener('change', function() {
            const value = this.value;
            const selectedCount = counts[value] ?? 0;
            if (deleteNoItemsDescription) {
                deleteNoItemsDescription.style.display = 'none';
            }

            if (value) {
                if (selectedCount > 0) {
                    deleteDescription.style.display = 'block';
                    deleteDescriptionText.textContent = descriptions[value];
                    deleteButton.disabled = false;
                    deleteButton.classList.remove('disabled');
                    deleteButton.setAttribute('data-action', actions[value]);
                    deleteButton.setAttribute('data-confirm', confirmMessages[value]);
                } else {
                    deleteDescription.style.display = 'none';
                    deleteButton.disabled = true;
                    deleteButton.classList.add('disabled');
                    if (deleteNoItemsDescription) {
                        deleteNoItemsDescription.style.display = 'block';
                    }
                }
            } else {
                deleteDescription.style.display = 'none';
                deleteButton.disabled = true;
                deleteButton.classList.add('disabled');
                if (deleteNoItemsDescription) {
                    deleteNoItemsDescription.style.display = 'none';
                }
            }
        });

        // Handle delete button click
        deleteButton.addEventListener('click', function() {
            const action = this.getAttribute('data-action');
            const confirmMessage = this.getAttribute('data-confirm');
            const selectedValue = deleteTypeSelect.value;

            if (action) {
                {% if settings.backupEnabled %}
                // Add backup notice to confirmation for dangerous actions
                const backupNotice = '\n\n{{ "Note: A backup will be created automatically before deleting."|t('translation-manager')|e('js') }}';
                const fullMessage = confirmMessage + backupNotice;
                {% else %}
                const fullMessage = confirmMessage;
                {% endif %}

                if (!confirm(fullMessage)) {
                    return;
                }
                // Create a form and submit it
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '';
                form.style.display = 'none';

                // Add CSRF token
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = '{{ craft.app.config.general.csrfTokenName }}';
                csrfInput.value = '{{ craft.app.request.csrfToken }}';
                form.appendChild(csrfInput);

                // Add action input
                const actionInput = document.createElement('input');
                actionInput.type = 'hidden';
                actionInput.name = 'action';
                actionInput.value = action;
                form.appendChild(actionInput);

                // Add category input if this is a per-category delete
                if (selectedValue.startsWith('category:')) {
                    const categoryInput = document.createElement('input');
                    categoryInput.type = 'hidden';
                    categoryInput.name = 'category';
                    categoryInput.value = selectedValue.substring(9); // Remove 'category:' prefix
                    form.appendChild(categoryInput);
                }

                if (selectedValue.startsWith('provider:')) {
                    const providerInput = document.createElement('input');
                    providerInput.type = 'hidden';
                    providerInput.name = 'provider';
                    providerInput.value = selectedValue.substring(9);
                    form.appendChild(providerInput);
                }

                // Add redirect input with proper hash
                const redirectInput = document.createElement('input');
                redirectInput.type = 'hidden';
                redirectInput.name = 'redirect';
                redirectInput.value = '{{ 'translation-manager/maintenance'|hash }}';
                form.appendChild(redirectInput);

                // Submit form
                document.body.appendChild(form);
                form.submit();
            }
        });
    }
{% endjs %}
